---
// Üç mockup'ta üç farklı isimle görülen aynı temel fikir (kapak + başlık + meta) — tek component,
// variant prop'uyla. Bkz. bilesen-envanteri.md §4.
// - compact: ana sayfa "Kitaplar" bölümü (yalnızca kapak + başlık)
// - grid: Kitaplar index (kapak + başlık + yıl + opsiyonel seri rozeti)
// - detail: Kitap detay "Diğer kitaplar" (kapak + başlık + rol/yıl meta metni)
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;
  cover: ImageMetadata;
  coverAlt: string;
  title: string;
  variant: 'compact' | 'grid' | 'detail';
  meta?: string; // grid: yıl ("2017"), detail: "Editör · 2019"
  seri?: string; // yalnızca grid varyantında, opsiyonel
}

const { href, cover, coverAlt, title, variant, meta, seri } = Astro.props;
---

<a class={`book-card book-card--${variant}`} href={href}>
  <div class="cover">
    <Image src={cover} alt={coverAlt} width={300} />
  </div>
  <p class="book-title">{title}</p>
  {meta && <p class="book-meta">{meta}</p>}
  {seri && <span class="seri-mark">{seri}</span>}
</a>

<style>
  .book-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .cover {
    aspect-ratio: 3 / 4;
    border-radius: var(--radius);
    background: var(--surface-1);
    margin-bottom: 8px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .book-card--grid .cover,
  .book-card--detail .cover {
    border: 0.5px solid var(--border);
  }
  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .book-title {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.35;
    margin: 0 0 4px;
  }
  .book-card--grid .book-title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .book-meta {
    font-size: 11.5px;
    color: var(--text-muted);
    margin: 0;
  }
  .book-card--detail .book-meta {
    margin-top: 2px;
  }
  .seri-mark {
    display: inline-block;
    margin-top: 5px;
    font-size: 10.5px;
    color: var(--text-muted);
    border: 0.5px dashed var(--border);
    border-radius: 999px;
    padding: 2px 8px;
  }
</style>
