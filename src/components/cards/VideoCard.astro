---
// Videolar index + Video detay "Diğer videolar" ortak kart — birebir aynı bileşen.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;
  thumbnail: ImageMetadata;
  thumbnailAlt: string;
  title: string;
  typeBadge: string; // video türü ("Söyleşi" vb.)
  sourceText: string; // "Medya Haber · 2025"
  duration: string; // "38 dk" — UI'da formatlanmış, schema'da dakika sayısı olarak tutuluyor
  area?: string; // araştırma alanı etiketi (opsiyonel — konu/alan henüz atanmamışsa)
}

const { href, thumbnail, thumbnailAlt, title, typeBadge, sourceText, duration, area } = Astro.props;
---

<a class="video-card" href={href}>
  <div class="thumb">
    <Image src={thumbnail} alt={thumbnailAlt} width={128} height={72} />
    <div class="play-badge">
      <svg width="26" height="26" viewBox="0 0 26 26"><circle cx="13" cy="13" r="12.5" fill="none" stroke="#fff" stroke-width="1.3"/><path d="M10.5 8.5l7.5 4.5-7.5 4.5z" fill="#fff"/></svg>
    </div>
    <span class="duration-tag">{duration}</span>
  </div>
  <div class="video-info">
    <p class="video-title">{title}</p>
    <div class="video-meta-row">
      <span class="type-badge">{typeBadge}</span>
      <span class="dot">·</span>
      <span>{sourceText}</span>
    </div>
    {area && <span class="area-pill">{area}</span>}
  </div>
</a>

<style>
  .video-card {
    display: flex;
    gap: 12px;
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: 10px;
    padding: 10px;
    min-height: 118px;
    align-items: stretch;
    text-decoration: none;
    color: inherit;
  }
  .thumb {
    width: 128px;
    height: 72px;
    flex-shrink: 0;
    border-radius: 6px;
    background: var(--surface-1);
    position: relative;
    overflow: hidden;
    align-self: center;
  }
  .thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .play-badge {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .duration-tag {
    position: absolute;
    bottom: 4px;
    right: 4px;
    background: rgba(0, 0, 0, 0.68);
    color: #fff;
    font-size: 10px;
    padding: 1px 5px;
    border-radius: 3px;
    line-height: 1.4;
  }
  .video-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-height: 0;
  }
  .video-title {
    font-size: 13.5px;
    font-weight: 500;
    line-height: 1.35;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .video-meta-row {
    font-size: 11.5px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 5px;
    flex-wrap: wrap;
  }
  .type-badge {
    font-size: 10.5px;
    padding: 2px 7px;
    border-radius: 999px;
    background: var(--surface-1);
    color: var(--text-secondary);
  }
  .dot {
    opacity: 0.6;
  }
  .area-pill {
    font-size: 11px;
    padding: 3px 9px;
    border-radius: 999px;
    font-weight: 500;
    background: rgba(24, 95, 165, 0.1);
    color: var(--text-accent);
    border: 0.5px solid rgba(24, 95, 165, 0.3);
    display: inline-block;
    margin-top: auto;
    width: fit-content;
  }
</style>
