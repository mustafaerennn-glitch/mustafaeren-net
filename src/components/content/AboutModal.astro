---
// Kitap detay + Video detay ortak — "X hakkında" tetikleyici buton + <dialog>. Native <dialog>
// kullanıldığı için ek bir JS kütüphanesi gerekmiyor, yalnızca showModal()/close() çağrıları.

interface Props {
  id: string;
  triggerLabel: string;
  title: string;
  metaLine: string;
}

const { id, triggerLabel, title, metaLine } = Astro.props;
---

<button type="button" class="btn-secondary" data-modal-trigger={id}>{triggerLabel}</button>

<dialog id={id}>
  <h3>{title}</h3>
  <p class="modal-meta">{metaLine}</p>
  <slot />
  <button type="button" class="modal-close" data-modal-close={id}>Kapat</button>
</dialog>

<script>
  document.querySelectorAll('[data-modal-trigger]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-modal-trigger');
      const dialog = id && document.getElementById(id);
      if (dialog instanceof HTMLDialogElement) dialog.showModal();
    });
  });
  document.querySelectorAll('[data-modal-close]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-modal-close');
      const dialog = id && document.getElementById(id);
      if (dialog instanceof HTMLDialogElement) dialog.close();
    });
  });
</script>

<style>
  .btn-secondary {
    font-size: 13px;
    font-family: var(--font-sans);
    border-radius: var(--radius);
    padding: 9px 18px;
    cursor: pointer;
    border: 0.5px solid var(--border);
    color: var(--text-primary);
    background: transparent;
    text-decoration: none;
    display: inline-block;
  }
  dialog {
    max-width: 480px;
    width: 90%;
    border: none;
    border-radius: 12px;
    padding: 1.75rem;
    background: var(--surface-2);
    color: var(--text-primary);
  }
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
  }
  dialog h3 {
    font-size: 17px;
    font-weight: 500;
    margin: 0 0 4px;
  }
  dialog .modal-meta {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 14px;
  }
  dialog :global(p) {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 12px;
  }
  dialog .modal-close {
    margin-top: 8px;
    font-size: 13px;
    background: transparent;
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 8px 16px;
    cursor: pointer;
    color: var(--text-primary);
  }
</style>
