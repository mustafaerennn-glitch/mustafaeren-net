---
import { getEntry, render, type CollectionEntry } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MecraRozeti from '../metadata/MecraRozeti.astro';
import MetaCluster from '../metadata/MetaCluster.astro';
import EditorNote from '../metadata/EditorNote.astro';
import TopicsRow from '../metadata/TopicsRow.astro';
import PreviewImage from './PreviewImage.astro';
import ArticleBody from './ArticleBody.astro';
import ShareRow from './ShareRow.astro';
import SourcesBlock from './SourcesBlock.astro';
import { getTranslationCluster } from '../../i18n/translationLookup';
import { contentUrl, routes, BREADCRUMB_HOME_LABEL, BASINDA_LABEL } from '../../i18n/routes';
import { getAreasForTopicRefs, getTopicsMap, ALAN_LABELS, ALAN_LABELS_I18N } from '../../lib/taxonomy';
import { TOPIC_LABELS_I18N } from '../../i18n/topics';

interface Props {
  entry: CollectionEntry<'basinda'>;
}

const { entry } = Astro.props;
const lang = entry.data.lang;
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}

const { Content } = await render(entry);
const cluster = await getTranslationCluster('basinda', entry);
const canonical = contentUrl('basinda', lang, entry.id);
const alternates = cluster.map((c) => ({ lang: c.lang, href: contentUrl('basinda', c.lang, c.slug) }));

const mecra = await getEntry(entry.data.mecra);

const localePrefix = lang === 'tr' ? '' : `/${lang}`;
const areaSlugs = await getAreasForTopicRefs(entry.data.topics);
const topicsMap = await getTopicsMap();
const alanLabels = lang === 'tr' ? ALAN_LABELS : ALAN_LABELS_I18N[lang];
const topics = entry.data.topics
  .map((ref) => topicsMap.get(ref.id))
  .filter((t): t is NonNullable<typeof t> => Boolean(t))
  .map((t) => ({
    slug: t.id,
    label: lang === 'tr' ? t.data.ad : (TOPIC_LABELS_I18N[lang][t.id] ?? t.data.ad),
    href: `${localePrefix}/konu/${t.id}/`,
  }));
const areas = areaSlugs.map((slug) => ({ slug, label: alanLabels[slug], href: `${localePrefix}/alanlar/${slug}/` }));

const siteUrl = new URL(canonical, 'https://mustafaeren.net').toString();

// Ana sayfa artık 4 dilde de gerçek (bkz. src/pages/{en,de,fr}/index.astro).
const homeHref = routes.anaSayfa[lang];

// Kaynaklar bloğu SADECE birden fazla kaynak olduğunda render edilir (talimat).
let sourcesData: { primary: { name: string; title: string; url?: string }; secondary: { name: string; title: string; url?: string }[] } | null = null;
if (entry.data.sources && entry.data.sources.length > 0) {
  const resolved = await Promise.all(
    entry.data.sources.map(async (s) => ({ mecra: await getEntry(s.mecra), tur: s.tur })),
  );
  const primaryItem = resolved.find((s) => s.tur === 'birincil') ?? resolved[0];
  sourcesData = {
    primary: { name: primaryItem.mecra.data.ad, title: entry.data.title, url: primaryItem.mecra.data.url },
    secondary: resolved
      .filter((s) => s !== primaryItem)
      .map((s) => ({ name: s.mecra.data.ad, title: entry.data.title, url: s.mecra.data.url })),
  };
}

const ogImage = await getImage({ src: entry.data.featuredImage, width: 1200 });
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  alternates={alternates}
  current="basinda"
  image={ogImage.src}
  ogType="article"
  pagefindType="Basında"
  pagefindMecra={mecra.data.ad}
  breadcrumb={[{ label: BREADCRUMB_HOME_LABEL[lang], href: homeHref }, { label: BASINDA_LABEL[lang], href: '/basinda/' }, { label: entry.data.title }]}
>
  <MecraRozeti mecra={{ ad: mecra.data.ad, url: mecra.data.url }} />

  <h1 class="title">{entry.data.title}</h1>

  <MetaCluster
    date={entry.data.publishDate}
    lang={lang}
    langItems={cluster.map((c) => ({ lang: c.lang, href: contentUrl('basinda', c.lang, c.slug) }))}
    pdfHref={entry.data.pdf}
  />

  {entry.data.editorNote && <EditorNote>{entry.data.editorNote}</EditorNote>}

  <PreviewImage image={entry.data.featuredImage} alt={entry.data.featuredImageAlt} />

  <ArticleBody>
    <Content />
  </ArticleBody>

  {sourcesData && <SourcesBlock primary={sourcesData.primary} secondary={sourcesData.secondary} />}

  <ShareRow url={siteUrl} title={entry.data.title} />

  <TopicsRow areas={areas} topics={topics} />
</BaseLayout>

<style>
  .title {
    font-size: 26px;
    line-height: 1.35;
  }
</style>
