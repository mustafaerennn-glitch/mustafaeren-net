---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicsRow from '../metadata/TopicsRow.astro';
import LangCluster from '../metadata/LangCluster.astro';
import ArticleBody from './ArticleBody.astro';
import BookCard from '../cards/BookCard.astro';
import KunyeBlock from './KunyeBlock.astro';
import { getAreasForTopicRefs, getTopicsMap, ALAN_LABELS, ALAN_LABELS_I18N } from '../../lib/taxonomy';
import { getTranslationCluster } from '../../i18n/translationLookup';
import { contentUrl, routes, LANG_NAMES } from '../../i18n/routes';
import { TOPIC_LABELS_I18N } from '../../i18n/topics';
import { ui } from '../../i18n/ui';

interface Props {
  entry: CollectionEntry<'kitaplar'>;
}

const { entry } = Astro.props;
const lang = entry.data.lang;
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}
const t = ui[lang];
const { Content } = await render(entry);
const localePrefix = lang === 'tr' ? '' : `/${lang}`;

const cluster = await getTranslationCluster('kitaplar', entry);
const canonical = `${localePrefix}/kitaplar/${entry.id}/`;
const alternates = cluster.map((c) => ({ lang: c.lang, href: contentUrl('kitaplar', c.lang, c.slug) }));

const KITAP_TURU_ROL: Record<string, Record<string, string>> = {
  tr: { yazdıklarım: 'Yazar', editörlük: 'Editör', katkılar: 'Katkı yazarı' },
  en: { yazdıklarım: 'Author', editörlük: 'Editor', katkılar: 'Contributor' },
  de: { yazdıklarım: 'Autor', editörlük: 'Herausgeber', katkılar: 'Mitwirkende(r)' },
  fr: { yazdıklarım: 'Auteur', editörlük: 'Éditeur', katkılar: 'Contributeur' },
};
const KITAP_TURU_BADGE: Record<string, Record<string, string>> = {
  tr: { yazdıklarım: 'Yazdıklarım', editörlük: 'Editörlük', katkılar: 'Katkılar' },
  en: { yazdıklarım: 'My Writing', editörlük: 'Edited', katkılar: 'Contributions' },
  de: { yazdıklarım: 'Eigene Texte', editörlük: 'Herausgeberschaft', katkılar: 'Beiträge' },
  fr: { yazdıklarım: 'Mes écrits', editörlük: 'Direction éditoriale', katkılar: 'Contributions' },
};
const rolLabel = KITAP_TURU_ROL[lang][entry.data.kitapTuru];
const badgeLabel = KITAP_TURU_BADGE[lang][entry.data.kitapTuru];

// Başlığın üstündeki küçük etiket artık "Yazar"/"Editör" gibi bir ROL kelimesi değil,
// doğrudan o roldeki kişinin/kişilerin adı — künyedeki ilgili satırdan okunuyor. Kural,
// kitapTuru'ndan değil kitapta GERÇEKTEN kimin ne olduğundan geliyor: bir "Yazar" varsa
// (kitap Mustafa Eren'in editörlüğünü yaptığı bir kitap olsa bile) her zaman yazarın adı
// gösterilir; yazar yoksa (derleme/konferans kitabı gibi) yayına hazırlayan/editör adına
// düşülür. İkisi de künyede yoksa (örn. çeviri özet sayfaları henüz künyeye geçirilmediyse
// veya mahpusun-ogrenim-hakki gibi isimli bir hazırlayanı olmayan broşürlerde) eski rol
// kelimesine geri düşülüyor.
const YAZAR_ETIKETLERI = ['Yazar', 'Author', 'Authors', 'Autor', 'Autoren', 'Auteur', 'Auteurs'];
const HAZIRLAYAN_ETIKETLERI = [
  'Editörler', 'Editör', 'Editors', 'Editor', 'Herausgeber', 'Herausgeberin', 'Éditeurs', 'Éditeur', 'Direction éditoriale',
  'Yayına Hazırlayan', 'Yayına Hazırlayanlar', 'Hazırlayanlar', 'Edited by', 'Herausgegeben von', 'Publié sous la direction de',
];
function eyebrowIsmi(): string {
  const yazar = entry.data.kunye?.find((k) => YAZAR_ETIKETLERI.includes(k.etiket));
  if (yazar) return yazar.deger;
  const hazirlayan = entry.data.kunye?.find((k) => HAZIRLAYAN_ETIKETLERI.includes(k.etiket));
  return hazirlayan?.deger ?? rolLabel;
}
const eyebrowLabel = eyebrowIsmi();

const areaSlugs = await getAreasForTopicRefs(entry.data.topics);
const topicsMap = await getTopicsMap();
const alanLabels = lang === 'tr' ? ALAN_LABELS : ALAN_LABELS_I18N[lang];
const topics = entry.data.topics
  .map((ref) => topicsMap.get(ref.id))
  .filter((tp): tp is NonNullable<typeof tp> => Boolean(tp))
  .map((tp) => ({
    slug: tp.id,
    label: lang === 'tr' ? tp.data.ad : (TOPIC_LABELS_I18N[lang][tp.id] ?? tp.data.ad),
    href: `${localePrefix}/konu/${tp.id}/`,
  }));
const areas = areaSlugs.map((slug) => ({ slug, label: alanLabels[slug], href: `${localePrefix}/alanlar/${slug}/` }));

const others = (await getCollection('kitaplar', (e) => e.data.lang === lang && e.id !== entry.id)).slice(0, 4);

const breadcrumbBaslik = t.navKitaplar;
const anaSayfaHref = routes.anaSayfa[lang];

const ogImage = await getImage({ src: entry.data.kapak, width: 1200 });
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  alternates={alternates}
  current="kitaplar"
  image={ogImage.src}
  pagefindType="Kitap"
  breadcrumb={[{ label: t.anaSayfa, href: anaSayfaHref }, { label: breadcrumbBaslik, href: `${localePrefix}/kitaplar/` }, { label: entry.data.title }]}
>
  <div class="book-hero">
    <div class="cover">
      <Image src={entry.data.kapak} alt={entry.data.kapakAlt} width={300} />
    </div>
    <div class="book-info">
      <div class="book-info-top">
        <p class="role-eyebrow">{eyebrowLabel}</p>
        <h1>{entry.data.title}</h1>
      </div>
      <div class="book-info-bottom">
        {
          entry.data.yayinDili && entry.data.yayinDili !== lang && (
            <p class="yayin-dili-line">{t.yayinDiliEtiket}: {LANG_NAMES[entry.data.yayinDili]}</p>
          )
        }
        {cluster.length > 1 && (
          <p class="lang-line">
            <LangCluster currentLang={lang} items={cluster.map((c) => ({ lang: c.lang, href: contentUrl('kitaplar', c.lang, c.slug) }))} />
          </p>
        )}
        <div class="cta-row">
          {entry.data.pdf && <a class="btn-primary" href={entry.data.pdf}>{t.pdfOku}</a>}
          {entry.data.yayineviUrl && (
            <a class="btn-secondary" href={entry.data.yayineviUrl} target="_blank" rel="noopener">{t.yayineviSayfasi}</a>
          )}
        </div>
        <div class="badges">
          <span class="badge">{badgeLabel}</span>
          {entry.data.seri && <span class="badge seri">{entry.data.seri}</span>}
        </div>
      </div>
    </div>
  </div>

  {entry.data.kunye && entry.data.kunye.length > 0 && <KunyeBlock items={entry.data.kunye} />}

  <ArticleBody>
    <Content />
  </ArticleBody>

  <TopicsRow areas={areas} topics={topics} />

  {
    others.length > 0 && (
      <div class="section" style="margin-bottom: 0;">
        <div class="section-head">
          <h2>{t.digerKitaplar}</h2>
          <a class="section-link" href={`${localePrefix}/kitaplar/`}>{t.tumunuGor}</a>
        </div>
        <div class="other-books-grid">
          {others.map((o) => (
            <BookCard href={`${localePrefix}/kitaplar/${o.id}/`} cover={o.data.kapak} coverAlt={o.data.kapakAlt} title={o.data.title} variant="detail" meta={`${KITAP_TURU_ROL[lang][o.data.kitapTuru]} · ${o.data.year}`} />
          ))}
        </div>
      </div>
    )
  }
</BaseLayout>

<style>
  h1 {
    font-size: 26px;
    line-height: 1.3;
  }
  .book-hero {
    display: flex;
    gap: 28px;
    margin-bottom: 1.75rem;
  }
  .cover {
    width: 168px;
    aspect-ratio: 2 / 3;
    flex-shrink: 0;
    border-radius: 6px;
    background: var(--surface-1);
    border: 0.5px solid var(--border);
    overflow: hidden;
  }
  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .book-info {
    flex: 1;
    min-width: 0;
    padding-top: 4px;
    display: flex;
    flex-direction: column;
  }
  .book-info-bottom {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: auto;
    margin-bottom: auto;
  }
  .role-eyebrow {
    font-size: 13px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }
  .yayin-dili-line {
    font-size: 12px;
    color: var(--text-muted);
    margin: 0;
  }
  .lang-line {
    font-size: 12px;
    margin: 0;
  }
  .badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 0;
  }
  .badge {
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 999px;
    border: 0.5px solid var(--border);
    color: var(--text-secondary);
  }
  .badge.seri {
    color: var(--text-muted);
    background: none;
    border-style: dashed;
  }
  .cta-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin: 0;
  }
  .btn-primary,
  .btn-secondary {
    font-size: 13px;
    font-family: var(--font-sans);
    border-radius: var(--radius);
    padding: 9px 18px;
    cursor: pointer;
    border: none;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.15s ease, opacity 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .btn-primary {
    background: var(--fill-primary);
    color: var(--on-primary);
  }
  .btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }
  .btn-secondary {
    background: transparent;
    border: 0.5px solid var(--border);
    color: var(--text-primary);
  }
  .btn-secondary:hover {
    border-color: var(--text-accent);
    color: var(--text-accent);
    transform: translateY(-1px);
  }
  .section {
    margin-bottom: 2.25rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-link {
    font-size: 13px;
    color: var(--text-accent);
    text-decoration: none;
  }
  .other-books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(112px, 1fr));
    gap: 14px;
  }
  @media (max-width: 600px) {
    .book-hero {
      flex-direction: column;
    }
    .cover {
      width: 150px;
    }
  }
</style>
