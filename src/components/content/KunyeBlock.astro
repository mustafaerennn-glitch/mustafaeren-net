---
// Kitap detay sayfasındaki yapısal künye (Yazar/Yayınevi/Basım Tarihi/Sayfa Sayısı/Kapak
// Tasarımı/ISBN gibi) — kutu/arka plan YOK, sayfayla aynı zeminde; ArticleBody'nin makale
// tipografisinden (büyük punto, geniş satır aralığı, birincil metin rengi) bilinçli olarak
// küçük punto + dar satır aralığı + soluk renkle ayrışır.
interface Props {
  items: { etiket: string; deger: string }[];
}

const { items } = Astro.props;
---

<dl class="kunye">
  {
    items.map(({ etiket, deger }) => (
      <div class="kunye-row">
        <dt>{etiket}</dt>
        <dd>{deger}</dd>
      </div>
    ))
  }
</dl>

<style>
  .kunye {
    margin: 0 0 1.75rem;
    padding-left: 10px;
  }
  .kunye-row {
    display: flex;
    flex-wrap: wrap;
    gap: 2px 8px;
    padding: 4px 0;
    font-size: 12.5px;
    line-height: 1.15;
  }
  .kunye-row dt {
    flex: 0 0 118px;
    color: var(--text-muted);
  }
  .kunye-row dd {
    flex: 1 1 200px;
    margin: 0;
    color: var(--text-primary);
    font-weight: 500;
  }
  @media (max-width: 480px) {
    .kunye-row dt {
      flex-basis: 100%;
    }
  }
</style>
