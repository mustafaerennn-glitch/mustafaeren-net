---
import { getEntry, render, type CollectionEntry } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MecraRozeti from '../metadata/MecraRozeti.astro';
import MetaCluster from '../metadata/MetaCluster.astro';
import EditorNote from '../metadata/EditorNote.astro';
import TopicsRow from '../metadata/TopicsRow.astro';
import PreviewImage from './PreviewImage.astro';
import ArticleBody from './ArticleBody.astro';
import ShareRow from './ShareRow.astro';
import { getTranslationCluster } from '../../i18n/translationLookup';
import { contentUrl, routes, BREADCRUMB_HOME_LABEL, YAZILAR_LABEL } from '../../i18n/routes';
import { getAreasForTopicRefs, getTopicsMap, ALAN_LABELS, ALAN_LABELS_I18N } from '../../lib/taxonomy';
import { TOPIC_LABELS_I18N } from '../../i18n/topics';

interface Props {
  entry: CollectionEntry<'yazilar'>;
}

const { entry } = Astro.props;
const lang = entry.data.lang;
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}

const { Content } = await render(entry);
const cluster = await getTranslationCluster('yazilar', entry);
const canonical = contentUrl('yazilar', lang, entry.id);
const alternates = cluster.map((c) => ({ lang: c.lang, href: contentUrl('yazilar', c.lang, c.slug) }));

const mecra = entry.data.mecra ? await getEntry(entry.data.mecra) : undefined;

const localePrefix = lang === 'tr' ? '' : `/${lang}`;
const areaSlugs = await getAreasForTopicRefs(entry.data.topics);
const topicsMap = await getTopicsMap();
const alanLabels = lang === 'tr' ? ALAN_LABELS : ALAN_LABELS_I18N[lang];
const topics = entry.data.topics
  .map((ref) => topicsMap.get(ref.id))
  .filter((t): t is NonNullable<typeof t> => Boolean(t))
  .map((t) => ({
    slug: t.id,
    label: lang === 'tr' ? t.data.ad : (TOPIC_LABELS_I18N[lang][t.id] ?? t.data.ad),
    href: `${localePrefix}/konu/${t.id}/`,
  }));
const areas = areaSlugs.map((slug) => ({ slug, label: alanLabels[slug], href: `${localePrefix}/alanlar/${slug}/` }));

const siteUrl = new URL(canonical, 'https://mustafaeren.net').toString();

// Ana sayfa artık 4 dilde de gerçek (bkz. src/pages/{en,de,fr}/index.astro).
const homeHref = routes.anaSayfa[lang];

// Open Graph/Twitter Card görseli — öne çıkan görsel zaten her Yazı'da zorunlu alan, elle
// bir şey girmeye gerek yok (bkz. BaseLayout'taki image prop notu).
const ogImage = await getImage({ src: entry.data.featuredImage, width: 1200 });
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  alternates={alternates}
  current="yazilar"
  image={ogImage.src}
  ogType="article"
  pagefindType="Yazı"
  pagefindMecra={mecra?.data.ad}
  breadcrumb={[{ label: BREADCRUMB_HOME_LABEL[lang], href: homeHref }, { label: YAZILAR_LABEL[lang], href: '/yazilar/' }, { label: entry.data.title }]}
>
  <MecraRozeti mecra={mecra ? { ad: mecra.data.ad, url: mecra.data.url } : undefined} />

  <h1 class="title">{entry.data.title}</h1>

  <MetaCluster
    date={entry.data.publishDate}
    lang={lang}
    langItems={cluster.map((c) => ({ lang: c.lang, href: contentUrl('yazilar', c.lang, c.slug) }))}
    pdfHref={entry.data.pdf}
  />

  {entry.data.editorNote && <EditorNote>{entry.data.editorNote}</EditorNote>}

  <PreviewImage image={entry.data.featuredImage} alt={entry.data.featuredImageAlt} />

  <ArticleBody>
    <Content />
  </ArticleBody>

  <ShareRow url={siteUrl} title={entry.data.title} />

  <TopicsRow areas={areas} topics={topics} />
</BaseLayout>

<style>
  .title {
    font-size: 26px;
    line-height: 1.35;
  }
</style>
