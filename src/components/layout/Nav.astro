---
import { ui, type Locale } from '../../i18n/ui';
import { routes, LANG_NAMES } from '../../i18n/routes';
import { ALAN_LABELS, ALAN_LABELS_I18N, ALAN_SLUGS } from '../../lib/taxonomy';
import { KITAP_TURU_SLUGS } from '../../lib/kitaplar';
import LangCluster from '../metadata/LangCluster.astro';
import Search from '../navigation/Search.astro';

// İlke (kullanıcı onaylı, revize edildi): Nav'daki menü öğeleri artık HER dilde her zaman
// gösterilir, içerik sayısı 0 olsa bile (örn. Fransızca'da "Videolar" görünür durumda kalır).
// Şeffaflık ilkesi: kullanıcı, sitenin diğer dillerde ne kadar içerik barındırdığını fark
// edebilsin. Her index sayfasının kendisinde ayrıca bir dil+sayı satırı var (bkz.
// LangCountRow.astro) — 0 içerikli diller orada da görünür ama tıklanamaz; Nav'daki link ise
// her zaman gerçek sayfaya gider.

interface Props {
  lang: Locale;
  current?: 'yazilar' | 'videolar' | 'kitaplar' | 'basinda' | 'konular' | 'hakkimda' | 'iletisim';
  // Yalnızca genel/indeks sayfaları bu listeyi doldurur (bkz. BaseLayout'taki showLangSwitcher).
  alternates?: { lang: Locale; href: string }[];
}

const { lang, current, alternates = [] } = Astro.props;
const t = ui[lang];
const showSwitcher = alternates.length > 1;
const otherLangs = alternates.filter((a) => a.lang !== lang);

const alanLabels = lang === 'tr' ? ALAN_LABELS : ALAN_LABELS_I18N[lang];
const ALANLAR = ALAN_SLUGS.filter((slug) => slug !== 'diger').map((slug) => ({ slug, label: alanLabels[slug] }));

const VIDEO_TURU_LABELS: Record<Locale, Record<string, string>> = {
  tr: { 'söyleşi': 'Söyleşi', belgesel: 'Belgesel', 'konferans-panel': 'Konferans / Panel', 'kısa-video': 'Kısa videolar' },
  en: { 'söyleşi': 'Interview', belgesel: 'Documentary', 'konferans-panel': 'Conference / Panel', 'kısa-video': 'Short videos' },
  de: { 'söyleşi': 'Gespräch', belgesel: 'Dokumentarfilm', 'konferans-panel': 'Konferenz / Podium', 'kısa-video': 'Kurzvideos' },
  fr: { 'söyleşi': 'Entretien', belgesel: 'Documentaire', 'konferans-panel': 'Conférence / Table ronde', 'kısa-video': 'Courtes vidéos' },
};
const VIDEO_TURLERI = (['söyleşi', 'belgesel', 'konferans-panel', 'kısa-video'] as const).map((tur) => ({
  tur,
  label: VIDEO_TURU_LABELS[lang][tur],
}));

const KITAP_TURU_LABELS: Record<Locale, Record<string, string>> = {
  tr: { yazdıklarım: 'Yazdıklarım', editörlük: 'Editörlük', katkılar: 'Katkılar' },
  en: { yazdıklarım: 'My Writing', editörlük: 'Edited', katkılar: 'Contributions' },
  de: { yazdıklarım: 'Eigene Texte', editörlük: 'Herausgeberschaft', katkılar: 'Beiträge' },
  fr: { yazdıklarım: 'Mes écrits', editörlük: 'Direction éditoriale', katkılar: 'Contributions' },
};
const KITAP_TURLERI = (['yazdıklarım', 'editörlük', 'katkılar'] as const).map((tip) => ({
  tip,
  label: KITAP_TURU_LABELS[lang][tip],
}));

const hakkimdaHref = routes.hakkimda[lang];
const iletisimHref = routes.iletisim[lang];
// Ana sayfa artık 4 dilde de gerçek (bkz. src/pages/{en,de,fr}/index.astro).
const brandHref = routes.anaSayfa[lang];

const localePrefix = lang === 'tr' ? '' : `/${lang}`;
const yazilarHref = `${localePrefix}/yazilar/`;
const basindaHref = `${localePrefix}/basinda/`;
---

<!-- Not: eskiden <header class="site-header"> içine sarılıydı. O sarmalayıcı kaldırıldı çünkü
     position:sticky elemanları kendi içinde bulunduğu block'un YÜKSEKLİĞİYLE sınırlı kalır —
     <header> yalnızca nav+dil-satırı kadar uzun bir kutuydu, bu yüzden sayfa o yüksekliği
     geçince sticky nav yapışık kalmayı bırakıp kayboluyordu. .topnav ve .lang-row artık
     doğrudan .page'in (tüm sayfa kadar uzun) çocukları, sticky boyunca "yapışacak yer" var. -->
<nav class:list={['topnav', { 'has-switcher': showSwitcher }]}>
  <a class="brand" href={brandHref}>Mustafa Eren</a>
  <div class="nav-items">
    <a class:list={['nav-link', { current: current === 'yazilar' }]} href={yazilarHref}>{t.navYazilar}</a>

    <details class="dropdown">
      <summary class:list={{ current: current === 'videolar' }}>{t.navVideolar}</summary>
      <div class="menu">
        <a href={`${localePrefix}/videolar/`}>{t.pillTumu}</a>
        {VIDEO_TURLERI.map((v) => <a href={`${localePrefix}/videolar/?tur=${v.tur}`}>{v.label}</a>)}
      </div>
    </details>

    <details class="dropdown">
      <summary class:list={{ current: current === 'kitaplar' }}>{t.navKitaplar}</summary>
      <div class="menu">
        <a href={`${localePrefix}/kitaplar/`}>{t.pillTumu}</a>
        {KITAP_TURLERI.map((k) => <a href={`${localePrefix}/kitaplar/tip/${KITAP_TURU_SLUGS[k.tip]}/`}>{k.label}</a>)}
      </div>
    </details>

    <a class:list={['nav-link', { current: current === 'basinda' }]} href={basindaHref}>{t.navBasinda}</a>

    <details class="dropdown">
      <summary class:list={{ current: current === 'konular' }}>{t.navKonular}</summary>
      <div class="menu">
        {ALANLAR.map((a) => <a href={`${localePrefix}/alanlar/${a.slug}/`}>{a.label}</a>)}
      </div>
    </details>

    <a class:list={['nav-link', { current: current === 'hakkimda' }]} href={hakkimdaHref}>{t.navHakkimda}</a>
    <a class:list={['nav-link', { current: current === 'iletisim' }]} href={iletisimHref}>{t.navIletisim}</a>
  </div>

  <div class="nav-actions">
    <Search lang={lang} />

    {
      showSwitcher && (
        <details class="dropdown lang-icon">
          <summary aria-label={t.dilSecAriaLabel}>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <path d="M12 3c2.5 2.5 3.8 6 3.8 9s-1.3 6.5-3.8 9c-2.5-2.5-3.8-6-3.8-9s1.3-6.5 3.8-9z" />
            </svg>
          </summary>
          <div class="menu">
            {otherLangs.map((a) => <a href={a.href}>{LANG_NAMES[a.lang]}</a>)}
          </div>
        </details>
      )
    }

    <details class="dropdown mobile-menu">
      <summary aria-label={t.menuAriaLabel}>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </summary>
      <div class="menu mobile-menu-list">
        <a class:list={{ current: current === 'yazilar' }} href={yazilarHref}>{t.navYazilar}</a>

        <details class="mobile-submenu">
          <summary class:list={{ current: current === 'videolar' }}>{t.navVideolar}</summary>
          <div class="mobile-submenu-list">
            <a href={`${localePrefix}/videolar/`}>{t.pillTumu}</a>
            {VIDEO_TURLERI.map((v) => <a href={`${localePrefix}/videolar/?tur=${v.tur}`}>{v.label}</a>)}
          </div>
        </details>

        <details class="mobile-submenu">
          <summary class:list={{ current: current === 'kitaplar' }}>{t.navKitaplar}</summary>
          <div class="mobile-submenu-list">
            <a href={`${localePrefix}/kitaplar/`}>{t.pillTumu}</a>
            {KITAP_TURLERI.map((k) => <a href={`${localePrefix}/kitaplar/tip/${KITAP_TURU_SLUGS[k.tip]}/`}>{k.label}</a>)}
          </div>
        </details>

        <a class:list={{ current: current === 'basinda' }} href={basindaHref}>{t.navBasinda}</a>

        <details class="mobile-submenu">
          <summary class:list={{ current: current === 'konular' }}>{t.navKonular}</summary>
          <div class="mobile-submenu-list">
            {ALANLAR.map((a) => <a href={`${localePrefix}/alanlar/${a.slug}/`}>{a.label}</a>)}
          </div>
        </details>

        <a class:list={{ current: current === 'hakkimda' }} href={hakkimdaHref}>{t.navHakkimda}</a>
        <a class:list={{ current: current === 'iletisim' }} href={iletisimHref}>{t.navIletisim}</a>
      </div>
    </details>
  </div>
</nav>

{
  showSwitcher && (
    <div class="lang-row">
      <LangCluster currentLang={lang} items={alternates} />
    </div>
  )
}

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--surface-0);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0 1rem;
    border-bottom: 0.5px solid var(--border);
    flex-wrap: wrap;
    gap: 12px;
  }
  .topnav:not(.has-switcher) {
    margin-bottom: 2rem;
  }
  .topnav.has-switcher {
    margin-bottom: 0.75rem;
  }
  .lang-row {
    position: sticky;
    top: var(--nav-height, 0px);
    z-index: 25;
    background: var(--surface-0);
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 12px;
  }
  .brand {
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    color: var(--text-primary);
  }
  .nav-items {
    display: flex;
    gap: 18px;
    font-size: 13px;
    color: var(--text-secondary);
    flex-wrap: wrap;
    align-items: center;
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .nav-actions .lang-icon,
  .nav-actions .mobile-menu {
    display: none;
  }
  .nav-actions .dropdown > summary {
    display: flex;
  }
  .nav-actions .dropdown > summary::after {
    content: none;
  }
  .nav-link {
    color: inherit;
    text-decoration: none;
  }
  .nav-link.current {
    color: var(--text-primary);
    font-weight: 500;
  }
  .dropdown {
    position: relative;
  }
  .dropdown summary {
    list-style: none;
    cursor: pointer;
    color: var(--text-secondary);
  }
  .dropdown summary.current {
    color: var(--text-primary);
    font-weight: 500;
  }
  .dropdown summary::-webkit-details-marker {
    display: none;
  }
  .dropdown summary::after {
    content: ' ▾';
    font-size: 10px;
  }
  .dropdown .menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 6px;
    display: flex;
    flex-direction: column;
    min-width: 160px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    z-index: 10;
  }
  .dropdown .menu a {
    padding: 6px 10px;
    border-radius: 6px;
    color: var(--text-secondary);
    text-decoration: none;
    white-space: nowrap;
  }
  .dropdown .menu a:hover {
    background: var(--surface-1);
    color: var(--text-primary);
  }
  .mobile-submenu summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    color: var(--text-secondary);
    font-size: 14.5px;
    padding: 10px 4px;
  }
  .mobile-submenu summary::-webkit-details-marker {
    display: none;
  }
  /* Aşağı ok — punto farkı yerine, "bunun alt seçenekleri var" bilgisini taşıyan tek işaret
     bu (talimat: tüm ana menü öğeleri aynı punto/kalınlıkta olmalı, ayrım yalnızca oktan
     gelmeli). Kapalıyken aşağı, açıkken yukarı bakacak şekilde döner. */
  .mobile-submenu summary::after {
    content: '';
    width: 7px;
    height: 7px;
    border-right: 1.5px solid var(--text-muted);
    border-bottom: 1.5px solid var(--text-muted);
    transform: rotate(45deg);
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }
  .mobile-submenu[open] > summary::after {
    transform: rotate(225deg);
  }
  .mobile-submenu summary.current {
    color: var(--text-primary);
    font-weight: 500;
  }
  .mobile-submenu-list {
    display: flex;
    flex-direction: column;
    padding-left: 14px;
    border-left: 0.5px solid var(--border);
    margin: 4px 0 4px 6px;
  }
  @media (max-width: 600px) {
    /* Nav artık iki satır: marka + sağa yanaşık aksiyon çubuğu (ara/dil/menü). İkisi de
       .topnav içinde olduğu için sticky birlikte davranır (talimat). */
    .nav-items {
      display: none;
    }
    .nav-actions {
      flex-basis: 100%;
      justify-content: flex-end;
    }
    .nav-actions .lang-icon,
    .nav-actions .mobile-menu {
      display: block;
    }
    /* Eskiden mobilde tüm sticky bar'lar kaldırılmıştı (dikey alan endişesiyle) — artık nav
       tek, ince bir iki-satırlık çubuğa indiği için tekrar sticky yapılması istendi (talimat). */
    .lang-row {
      display: none;
    }
    /* .menu, .dropdown'ın (yakın konumlanmış atası) kutusuna göre mutlak konumlanır — bu
       yüzden .lang-icon/.mobile-menu'nün KENDİ position:relative'i devre dışı bırakılıyor,
       böylece .menu bunun yerine .topnav'a (sticky, dolayısıyla kendisi de bir konumlama
       bağlamı) göre tam genişlikte yerleşiyor. Böylece sayfa kaydırılmamış haldeyken de
       (nav henüz viewport'un üstüne yapışmamışken) panel doğru yerde açılıyor — sabit bir
       piksel değeriyle değil, nav'ın GERÇEK anlık konumuna göre. */
    .lang-icon,
    .mobile-menu {
      position: static;
    }
    .dropdown.lang-icon .menu,
    .dropdown.mobile-menu .menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      min-width: 0;
      /* Talimat: panel tüm ekranı kaplamasın, altındaki sayfa görünmeye devam etsin —
         hem yükseklik sınırlı hem de zemin yarı saydam/bulanık (frosted glass). */
      max-height: 50vh;
      overflow-y: auto;
      padding: 10px 20px 20px;
      border-radius: 0 0 var(--radius) var(--radius);
      border-width: 0.5px 0.5px 0.5px 0;
      background: rgba(247, 246, 242, 0.7);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
      z-index: 40;
    }
    .dropdown.lang-icon .menu a,
    .dropdown.mobile-menu .menu a {
      padding: 10px 4px;
      font-size: 14.5px;
    }
    .dropdown.mobile-menu .menu > a.current {
      color: var(--text-primary);
      font-weight: 500;
    }
  }
</style>

<script>
  // Açık bir dropdown'ın dışına tıklanınca kapanır (talimat: bu artık evrensel bir refleks).
  document.addEventListener('click', (e) => {
    document.querySelectorAll<HTMLDetailsElement>('.dropdown[open]').forEach((details) => {
      if (!details.contains(e.target as Node)) details.removeAttribute('open');
    });
  });

  // Sticky yığın senkronizasyonu: navbar + dil satırının GERÇEK yüksekliklerini ölçüp
  // :root üzerinde CSS custom property olarak yayınlıyoruz. Nav.astro'daki .lang-row (top:
  // var(--nav-height)) ve Breadcrumb.astro'daki .breadcrumb (top: var(--nav-stack-height))
  // bu değerleri okuyor — böylece navbar'ın padding/yüksekliği ileride değişirse hardcode
  // píxel değerlerini elle güncellemek gerekmiyor, ResizeObserver otomatik yeniden hesaplıyor.
  function syncStickyOffsets() {
    const topnav = document.querySelector<HTMLElement>('.topnav');
    const langRow = document.querySelector<HTMLElement>('.lang-row');
    const navHeight = topnav?.getBoundingClientRect().height ?? 0;
    const langRowHeight = langRow ? langRow.getBoundingClientRect().height : 0;
    const root = document.documentElement.style;
    root.setProperty('--nav-height', `${navHeight}px`);
    root.setProperty('--nav-stack-height', `${navHeight + langRowHeight}px`);
  }

  syncStickyOffsets();

  const resizeObserver = new ResizeObserver(() => syncStickyOffsets());
  document.querySelectorAll<HTMLElement>('.topnav, .lang-row').forEach((el) => resizeObserver.observe(el));
  window.addEventListener('resize', syncStickyOffsets);
</script>
