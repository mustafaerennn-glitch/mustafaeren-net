---
import { ui, type Locale } from '../../i18n/ui';
import { routes, LANG_NAMES } from '../../i18n/routes';
import { ALAN_LABELS, ALAN_LABELS_I18N, ALAN_SLUGS } from '../../lib/taxonomy';
import { getContentAvailability } from '../../lib/availability';
import LangCluster from '../metadata/LangCluster.astro';

// İlke (kullanıcı onaylı): kullanıcı hangi dili seçtiyse, yalnızca o dilde mevcut içerik
// gösterilir — başka dile fallback YOK. Bir koleksiyonda (Yazılar/Basında/Videolar/Kitaplar)
// o dilde hiç gerçek girdi yoksa, o menü öğesi bu dilde hiç gösterilmez (bkz. lib/availability.ts).
// İletişim'in henüz per-locale sayfası yok, o yüzden TR'ye gider (ayrı, bilinen bir eksik).

interface Props {
  lang: Locale;
  current?: 'yazilar' | 'videolar' | 'kitaplar' | 'basinda' | 'konular' | 'hakkimda' | 'iletisim';
  // Yalnızca genel/indeks sayfaları bu listeyi doldurur (bkz. BaseLayout'taki showLangSwitcher).
  alternates?: { lang: Locale; href: string }[];
}

const { lang, current, alternates = [] } = Astro.props;
const t = ui[lang];
const showSwitcher = alternates.length > 1;
const otherLangs = alternates.filter((a) => a.lang !== lang);
const availability = await getContentAvailability(lang);

const alanLabels = lang === 'tr' ? ALAN_LABELS : ALAN_LABELS_I18N[lang];
const ALANLAR = ALAN_SLUGS.filter((slug) => slug !== 'diger').map((slug) => ({ slug, label: alanLabels[slug] }));

const VIDEO_TURLERI = [
  { tur: 'söyleşi', label: 'Söyleşi' },
  { tur: 'belgesel', label: 'Belgesel' },
  { tur: 'konferans-panel', label: 'Konferans / Panel' },
  { tur: 'kısa-video', label: 'Kısa videolar' },
] as const;

const KITAP_TURLERI = [
  { tip: 'yazdıklarım', label: 'Yazdıklarım' },
  { tip: 'editörlük', label: 'Editörlük' },
  { tip: 'katkılar', label: 'Katkılar' },
] as const;

const hakkimdaHref = routes.hakkimda[lang];
// Ana sayfa artık 4 dilde de gerçek (bkz. src/pages/{en,de,fr}/index.astro).
const brandHref = routes.anaSayfa[lang];

const localePrefix = lang === 'tr' ? '' : `/${lang}`;
const yazilarHref = `${localePrefix}/yazilar/`;
const basindaHref = `${localePrefix}/basinda/`;
---

<header class="site-header">
  <nav class:list={['topnav', { 'has-switcher': showSwitcher }]}>
    <a class="brand" href={brandHref}>Mustafa Eren</a>
    <div class="nav-items">
      {availability.yazilar && (
        <a class:list={['nav-link', { current: current === 'yazilar' }]} href={yazilarHref}>{t.navYazilar}</a>
      )}

      {availability.videolar && (
        <details class="dropdown">
          <summary class:list={{ current: current === 'videolar' }}>{t.navVideolar}</summary>
          <div class="menu">
            <a href={`${localePrefix}/videolar/`}>{t.pillTumu}</a>
            {VIDEO_TURLERI.map((v) => <a href={`${localePrefix}/videolar/?tur=${v.tur}`}>{v.label}</a>)}
          </div>
        </details>
      )}

      {availability.kitaplar && (
        <details class="dropdown">
          <summary class:list={{ current: current === 'kitaplar' }}>{t.navKitaplar}</summary>
          <div class="menu">
            <a href={`${localePrefix}/kitaplar/`}>{t.pillTumu}</a>
            {KITAP_TURLERI.map((k) => <a href={`${localePrefix}/kitaplar/?tip=${k.tip}`}>{k.label}</a>)}
          </div>
        </details>
      )}

      {availability.basinda && (
        <a class:list={['nav-link', { current: current === 'basinda' }]} href={basindaHref}>{t.navBasinda}</a>
      )}

      <details class="dropdown">
        <summary class:list={{ current: current === 'konular' }}>{t.navKonular}</summary>
        <div class="menu">
          {ALANLAR.map((a) => <a href={`${localePrefix}/alanlar/${a.slug}/`}>{a.label}</a>)}
        </div>
      </details>

      <a class:list={['nav-link', { current: current === 'hakkimda' }]} href={hakkimdaHref}>{t.navHakkimda}</a>
      <a class:list={['nav-link', { current: current === 'iletisim' }]} href="/iletisim/">{t.navIletisim}</a>
    </div>
  </nav>

  {
    showSwitcher && (
      <div class="lang-row">
        <span class="lang-row-desktop">
          <LangCluster currentLang={lang} items={alternates} />
        </span>
        <details class="dropdown lang-dropdown">
          <summary>{LANG_NAMES[lang]}</summary>
          <div class="menu">
            {otherLangs.map((a) => <a href={a.href}>{LANG_NAMES[a.lang]}</a>)}
          </div>
        </details>
      </div>
    )
  }
</header>

<style>
  .topnav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0 1rem;
    border-bottom: 0.5px solid var(--border);
    flex-wrap: wrap;
    gap: 12px;
  }
  .topnav:not(.has-switcher) {
    margin-bottom: 2rem;
  }
  .topnav.has-switcher {
    margin-bottom: 0.75rem;
  }
  .lang-row {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-bottom: 2rem;
  }
  .lang-row-desktop {
    font-size: 12px;
  }
  .lang-dropdown {
    display: none;
  }
  .brand {
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    color: var(--text-primary);
  }
  .nav-items {
    display: flex;
    gap: 18px;
    font-size: 13px;
    color: var(--text-secondary);
    flex-wrap: wrap;
    align-items: center;
  }
  .nav-link {
    color: inherit;
    text-decoration: none;
  }
  .nav-link.current {
    color: var(--text-primary);
    font-weight: 500;
  }
  .dropdown {
    position: relative;
  }
  .dropdown summary {
    list-style: none;
    cursor: pointer;
    color: var(--text-secondary);
  }
  .dropdown summary.current {
    color: var(--text-primary);
    font-weight: 500;
  }
  .dropdown summary::-webkit-details-marker {
    display: none;
  }
  .dropdown summary::after {
    content: ' ▾';
    font-size: 10px;
  }
  .dropdown .menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 6px;
    display: flex;
    flex-direction: column;
    min-width: 160px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    z-index: 10;
  }
  .dropdown .menu a {
    padding: 6px 10px;
    border-radius: 6px;
    color: var(--text-secondary);
    text-decoration: none;
    white-space: nowrap;
  }
  .dropdown .menu a:hover {
    background: var(--surface-1);
    color: var(--text-primary);
  }
  @media (max-width: 600px) {
    .lang-row-desktop {
      display: none;
    }
    .lang-dropdown {
      display: block;
    }
    .lang-dropdown .menu {
      left: auto;
      right: 0;
    }
  }
</style>
