const TITLES: Record<string, string> = {
  x: 'X',
  facebook: 'Facebook',
  linkedin: 'LinkedIn',
  academia: 'Academia',
  youtube: 'YouTube',
  bluesky: 'Bluesky',
  scholar: 'Google Scholar',
