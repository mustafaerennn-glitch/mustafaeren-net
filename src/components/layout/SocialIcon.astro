interface Props {
  name: 'x' | 'facebook' | 'linkedin' | 'academia' | 'youtube' | 'bluesky' | 'scholar';
  size?: number;
}

const { name, size = 18 } = Astro.props;
const title = TITLES[name];
---

{
  name === 'linkedin' ? (
    <svg
      viewBox="0 0 24 24"
      width={size}
      height={size}
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <title>{title}</title>
      <rect x="3" y="3" width="18" height="18" rx="3" />
      <line x1="7.5" y1="10" x2="7.5" y2="17" />
      <circle cx="7.5" cy="6.8" r="0.9" fill="currentColor" stroke="none" />
      <line x1="11.5" y1="10" x2="11.5" y2="17" />
      <path d="M11.5 13.2c0-1.4.9-2.3 2.1-2.3 1.2 0 1.9.8 1.9 2.3V17" />
    </svg>
  ) : (
    <svg viewBox="0 0 24 24" width={size} height={size} fill="currentColor">
      <title>{title}</title>
      <path d={PATHS[name]} />
    </svg>
  )
}
