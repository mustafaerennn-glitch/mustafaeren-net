---
// Site arama tetikleyicisi — sade bir modal, yalnızca sorguyu alıp Enter'da sonuç sayfasına
// (routes.ara[lang]) yönlendirir. Gerçek arama (Pagefind) o sayfada çalışır — bkz.
// src/components/search/SearchResults.astro. Modalın kendisi Pagefind'a hiç dokunmuyor, bu
// yüzden dev sunucusunda da (build sonrası indeks üretilmeden) sorunsuz çalışır.
import { ui, type Locale } from '../../i18n/ui';
import { routes } from '../../i18n/routes';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = ui[lang];
const searchPath = routes.ara[lang];
---

<button type="button" class="search-trigger" aria-label={t.searchAriaLabel} data-search-open>
  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="7" />
    <line x1="21" y1="21" x2="16.65" y2="16.65" />
  </svg>
</button>

<dialog id="search-dialog" data-search-dialog data-search-path={searchPath}>
  <div class="search-head">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="7" />
      <line x1="21" y1="21" x2="16.65" y2="16.65" />
    </svg>
    <input type="search" placeholder={t.searchPlaceholder} data-search-input aria-label={t.searchAriaLabel} />
    <span class="search-hint">{t.searchHint}</span>
  </div>
</dialog>

<script>
  const openBtnQuery = document.querySelector('[data-search-open]');
  const dialogQuery = document.querySelector('[data-search-dialog]');
  const inputQuery = document.querySelector('[data-search-input]');

  if (openBtnQuery instanceof HTMLElement && dialogQuery instanceof HTMLDialogElement && inputQuery instanceof HTMLInputElement) {
    // Narrow'lanmış tipler kapatma (closure) fonksiyonlarına taşınmıyor — TS'in bilinen
    // sınırlaması. Bu yüzden yeniden bağlanıyor.
    const openBtnEl = openBtnQuery;
    const dialogEl = dialogQuery;
    const inputEl = inputQuery;
    const searchPath = dialogEl.dataset.searchPath || '/ara/';

    function openDialog() {
      dialogEl.showModal();
      inputEl.focus();
    }

    openBtnEl.addEventListener('click', openDialog);

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (dialogEl.open) {
          dialogEl.close();
        } else {
          openDialog();
        }
      }
    });

    dialogEl.addEventListener('click', (e) => {
      const rect = dialogEl.getBoundingClientRect();
      const inside = e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
      if (!inside) dialogEl.close();
    });

    dialogEl.addEventListener('close', () => {
      inputEl.value = '';
    });

    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const query = inputEl.value.trim();
        if (!query) return;
        window.location.href = `${searchPath}?q=${encodeURIComponent(query)}`;
      }
    });
  }
</script>

<style>
  .search-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    padding: 0;
    color: var(--text-secondary);
    cursor: pointer;
  }
  .search-trigger:hover {
    color: var(--text-primary);
  }
  dialog[data-search-dialog] {
    width: 90%;
    max-width: 560px;
    border: none;
    border-radius: 12px;
    padding: 0;
    background: var(--surface-2);
    color: var(--text-primary);
    margin-top: 10vh;
  }
  dialog[data-search-dialog]::backdrop {
    background: rgba(0, 0, 0, 0.4);
  }
  .search-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    color: var(--text-muted);
  }
  .search-head input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 15px;
    font-family: var(--font-sans);
    color: var(--text-primary);
  }
  .search-hint {
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
  }
  @media (max-width: 600px) {
    .search-hint {
      display: none;
    }
  }
</style>
