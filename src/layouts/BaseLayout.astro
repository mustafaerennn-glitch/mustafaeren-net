---
import '../styles/global.css';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import type { Locale } from '../i18n/routes';

interface Alternate {
  lang: Locale;
  href: string;
}

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  lang: Locale;
  title: string;
  description?: string;
  canonical: string;
  alternates?: Alternate[];
  current?: 'yazilar' | 'videolar' | 'kitaplar' | 'basinda' | 'konular' | 'hakkimda' | 'iletisim';
  breadcrumb?: Crumb[]; // ana sayfada verilmez — anlamsız (talimat)
  pageWidth?: string; // yalnızca Video sayfalarındaki bilinçli 760px istisnası için (bkz. bilesen-envanteri.md §6.1)
  // Site arama (Pagefind) kapsamı: yalnızca bu prop'u geçen sayfalar indekslenir (Yazı/Basında/
  // Video/Kitap detay sayfaları). Verilince <main>'e data-pagefind-body + tür meta'sı eklenir —
  // Pagefind'da bu attribute site genelinde bir kez kullanılınca, kullanılmayan TÜM sayfalar
  // (index/hub/Hakkımda/İletişim dahil) otomatik olarak indeks dışı kalır.
  pagefindType?: 'Yazı' | 'Basında' | 'Video' | 'Kitap';
  // Yalnızca mecrası olan Yazı/Basında/Video sayfaları geçer (Kitap'ta yayınevi var, mecra yok —
  // farklı kavramlar, bkz. taksonomi kararları). Arama sonuçlarında mecra rozeti göstermek için.
  pagefindMecra?: string;
  // Site geneli dil değiştirici Nav'da yalnızca genel/indeks sayfalarında (Ana Sayfa, Hakkımda,
  // İletişim, indeksler) gösterilir. İçerik detay sayfaları (Yazı/Basında) da hreflang için
  // `alternates` geçer ama kendi gövde-içi LangCluster'ı zaten var — Nav'da tekrar göstermek
  // roadmap'in "aynı bilgiyi tekrar etme" kuralını ihlal eder, bu yüzden ayrı bir bayrakla kontrol edilir.
  showLangSwitcher?: boolean;
  // Open Graph/Twitter Card görseli — çağıran sayfa getImage() ile işleyip elde ettiği src'yi
  // (göreli ya da mutlak) geçer. Verilmezse apple-touch-icon.png'ye düşülür (bkz. altta) — bu
  // sayede içerik sayfaları (Yazı/Basında/Video/Kitap zaten görsel taşıyor, otomatik bağlanıyor)
  // dışında hiçbir sayfa OG görselsiz kalmıyor, elle bir şey girmek gerekmiyor.
  image?: string;
  // article: Yazı/Basında/Video detay sayfaları (yayın tarihi olan içerik). Diğer her şey website.
  ogType?: 'website' | 'article';
}

const {
  lang,
  title,
  description,
  canonical,
  alternates = [],
  current,
  breadcrumb,
  pageWidth,
  showLangSwitcher = false,
  pagefindType,
  pagefindMecra,
  image,
  ogType = 'website',
} = Astro.props;

// Yalnızca gerçekten birden fazla dil sürümü varsa hreflang üretilir —
// tek dilli bir sayfada kendine referans veren hreflang anlamsız/gürültü olurdu.
const showHreflang = alternates.length > 1;
const trAlternate = alternates.find((a) => a.lang === 'tr');

// Lighthouse SEO denetimi göreli canonical/hreflang'ı geçersiz sayıyor — ikisi de mutlak URL olmalı.
const SITE_URL = 'https://mustafaeren.net';
const canonicalAbsolute = new URL(canonical, SITE_URL).toString();
const ogImageAbsolute = new URL(image ?? '/apple-touch-icon.png', SITE_URL).toString();
const OG_LOCALE: Record<Locale, string> = { tr: 'tr_TR', en: 'en_US', de: 'de_DE', fr: 'fr_FR' };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=2" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalAbsolute} />
    {showHreflang && alternates.map((a) => <link rel="alternate" hreflang={a.lang} href={new URL(a.href, SITE_URL).toString()} />)}
    {showHreflang && trAlternate && <link rel="alternate" hreflang="x-default" href={new URL(trAlternate.href, SITE_URL).toString()} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Mustafa Eren" />
    <meta property="og:locale" content={OG_LOCALE[lang]} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalAbsolute} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageAbsolute} />

    {
      // Yalnızca production build'de (deploy edilen site) yüklenir — geliştirme sırasında
      // (astro dev, localhost testleri) analitik verisini kirletmesin diye.
      import.meta.env.PROD && (
        <>
          <script is:inline type="module" src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "4cb702c6cf6c493f88d8a27cedff9688"}'></script>
        </>
      )
    }
  </head>
  <body>
    <div class="page" style={pageWidth ? `--page-width: ${pageWidth}` : undefined}>
      <Nav lang={lang} current={current} alternates={showLangSwitcher ? alternates : []} />
      <main
        data-pagefind-body={pagefindType ? true : undefined}
        data-pagefind-meta={pagefindType ? `type:${pagefindType}` : undefined}
        data-pagefind-filter={pagefindType ? `lang:${lang}` : undefined}
      >
        {
          /* Pagefind, TEK bir data-pagefind-meta attribute'unda virgülle birleştirilmiş
          birden fazla anahtarı doğru ayrıştırmıyor (denendi, "type" alanına ",mecra:..." kısmı
          da karışıyordu) — ikinci meta alanı için ayrı, görünmez bir eleman gerekiyor. */
        }
        {pagefindMecra && <span data-pagefind-meta={`mecra:${pagefindMecra}`} hidden />}
        {breadcrumb && <Breadcrumb items={breadcrumb} />}
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
