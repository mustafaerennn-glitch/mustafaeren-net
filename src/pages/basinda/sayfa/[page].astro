---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PressList from '../../../components/navigation/PressList.astro';
import PressRow from '../../../components/navigation/PressRow.astro';
import Pagination from '../../../components/navigation/Pagination.astro';
import { type Locale } from '../../../i18n/routes';
import LangCountRow from '../../../components/metadata/LangCountRow.astro';
import { getContentCountsByLang } from '../../../lib/availability';
import { buildBasindaRows, paginateRows, extraPageParams } from '../../../lib/pressPagination';

export async function getStaticPaths() {
  const allRows = await buildBasindaRows('tr');
  const { totalPages } = paginateRows(allRows, 1);
  return extraPageParams(totalPages);
}

const lang = 'tr';
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}

const page = Number(Astro.params.page);
const allRows = await buildBasindaRows(lang);
const { pageRows: rows, totalPages } = paginateRows(allRows, page);

const lastUpdate = allRows.length
  ? new Intl.DateTimeFormat(lang, { month: 'long', year: 'numeric' }).format(
      allRows.reduce((latest, r) => (r.publishDate > latest ? r.publishDate : latest), allRows[0].publishDate),
    )
  : null;

const langCounts = await getContentCountsByLang();
const langItems = (['tr', 'en', 'de', 'fr'] as Locale[]).map((l) => ({
  lang: l,
  href: l === 'tr' ? '/basinda/' : `/${l}/basinda/`,
  count: langCounts[l].basinda,
}));
---

<BaseLayout
  lang={lang}
  title="Basında"
  description="Söyleşiler, röportajlar ve hakkımda çıkan haberler — hapishane çalışmaları, göç ve yakın siyasal tarih üzerine."
  canonical={`/basinda/sayfa/${page}/`}
  current="basinda"
  breadcrumb={[{ label: 'Ana sayfa', href: '/' }, { label: 'Basında', href: '/basinda/' }, { label: `Sayfa ${page}` }]}
>
  <h1>Basında</h1>
  <p class="desc">Söyleşiler, röportajlar ve hakkımda çıkan haberler — hapishane çalışmaları, göç ve yakın siyasal tarih üzerine.</p>
  {lastUpdate && <p class="meta-line">{allRows.length} içerik · son güncelleme {lastUpdate}</p>}

  <LangCountRow currentLang={lang} items={langItems} />

  <PressList>
    {rows.map((row) => <PressRow href={row.href} title={row.title} date={row.date} secondary={row.secondary} />)}
  </PressList>

  <Pagination currentPage={page} totalPages={totalPages} basePath="/basinda/" />
</BaseLayout>

<style>
  .desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 520px;
    margin: 1rem 0 0.75rem;
  }
  .meta-line {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 1.75rem;
  }
</style>
