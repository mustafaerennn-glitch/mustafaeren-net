---
import { getCollection } from 'astro:content';
import BasindaDetaySayfasi from '../../../components/content/BasindaDetaySayfasi.astro';

export async function getStaticPaths() {
  const entries = await getCollection('basinda', (entry) => entry.data.lang === 'de');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
---

<BasindaDetaySayfasi entry={entry} />
