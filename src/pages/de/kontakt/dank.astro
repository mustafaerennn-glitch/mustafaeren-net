---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { routes } from '../../../i18n/routes';
import { ui } from '../../../i18n/ui';

const lang = 'de';
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}

const t = ui[lang];
---

<BaseLayout
  lang={lang}
  title={t.tesekkurBaslik}
  canonical={`${routes.iletisim.de}dank/`}
  current="iletisim"
  breadcrumb={[
    { label: t.anaSayfa, href: routes.anaSayfa.de },
    { label: t.navIletisim, href: routes.iletisim.de },
    { label: t.tesekkurler },
  ]}
>
  <h1>{t.tesekkurBaslikH1}</h1>
  <p class="desc">{t.tesekkurAciklama}</p>
  <a class="btn-secondary" href={routes.anaSayfa.de}>{t.anaSayfayaDon}</a>
</BaseLayout>

<style>
  .desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 1rem 0 1.75rem;
  }
  .btn-secondary {
    font-size: 13.5px;
    font-family: var(--font-sans);
    border-radius: var(--radius);
    padding: 9px 16px;
    border: 0.5px solid var(--border);
    background: transparent;
    color: var(--text-primary);
    text-decoration: none;
    display: inline-block;
  }
  .btn-secondary:hover {
    border-color: var(--text-accent);
    color: var(--text-accent);
  }
</style>
