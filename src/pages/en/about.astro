---
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { routes, type Locale } from '../../i18n/routes';
import { ui } from '../../i18n/ui';
import profilFoto from '../../assets/profil-fotografi.jpg';

const lang = 'en';
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}

const t = ui[lang];
const alternates = (Object.entries(routes.hakkimda) as [Locale, string][]).map(([l, href]) => ({ lang: l, href }));

const paragraphs = [
  "My undergraduate degree is from Mimar Sinan University of Fine Arts, Department of Sociology (Istanbul, Turkey). I hold a master's degree from Istanbul Bilgi University's Department of Cultural Studies, and I attended PhD seminars at Mimar Sinan University of Fine Arts. Between 2019 and 2020, I followed graduate courses as a visiting student at the University of Zurich. In 2026, I began the Migrationsfachperson (Migration Specialist) program at the Schule für Sozialbegleitung.",
  'My areas of work are prisons/confinement, labour, social movements, political history, migration, and disadvantaged groups.',
  'Since 2011, I have worked with the Civil Society in the Penal System Association (CİSST) as a project coordinator, board member, and chairman of the board. Together with Eva Tanz and Ayşegül Algan, I co-founded Turkey\'s Center for Prison Studies (TCPS) and the Prison Studies Library within the association.',
  'Between 2012 and 2024, together with a friend, I produced and hosted the program Emeğin Gündemi (The Labour Agenda) on Açık Radyo.',
  'In 2014, I taught a course on "Human Rights" at Arel University. Between 2012 and 2014, I served as a board member of the Association of Sociology Graduates (SOMDER).',
  'I have edited numerous books on prisons, and my writing has appeared in books, journals, and various online news outlets.',
  'I took part in and coordinated many projects at Mimar Sinan University and CİSST. I was also involved in founding the Istanbul Social Research Group (İSTAG).',
  'Due to ongoing lawsuits and the threat of imprisonment, I was forced to leave Turkey in 2018 and have continued my work abroad since then. Since 2023, alongside my research and writing, I have worked as a Betreuer (support worker) at a migration center.',
];

// Roadmap kararı: Hakkımda'daki gibi, editoryal olarak seçilmiş 5 kitap — önem sırasına göre
// (kronolojik değil, tarih sırasının tam tersi). Bu 5 TR kitabın gerçek İngilizce çeviri
// sayfaları — bkz. src/pages/hakkimda.astro'daki aynı karar.
const SECILI_KITAPLAR = [
  'turkey-prisons-almanac-2015',
  'my-rights-an-application-guide-for-prisoners',
  'handbook-of-prisoners-rights',
  'the-pathology-of-confinement',
  'kanli-pazar-nationalists-islamists-and-the-left',
];
const kitaplarMap = new Map((await getCollection('kitaplar')).filter((k) => k.data.lang === lang).map((k) => [k.id, k]));
const kitaplar = SECILI_KITAPLAR.map((id) => kitaplarMap.get(id)).filter((k) => k !== undefined);

const ogImage = await getImage({ src: profilFoto, width: 1200 });
---

<BaseLayout
  lang={lang}
  title={t.hakkimdaBaslik}
  description={paragraphs[0]}
  canonical={routes.hakkimda.en}
  alternates={alternates}
  showLangSwitcher
  current="hakkimda"
  image={ogImage.src}
  breadcrumb={[{ label: t.anaSayfa, href: routes.anaSayfa.en }, { label: t.hakkimdaBaslik }]}
>
  <div class="bio-hero">
    <div class="avatar">
      <Image src={profilFoto} alt="Mustafa Eren" width={304} height={304} />
    </div>
    <div class="bio-info">
      <h1>Mustafa Eren</h1>
      <p class="role-eyebrow">Sociologist · Researcher · Writer</p>
    </div>
  </div>
  <div class="bio-body">
    {paragraphs.map((p) => <p>{p}</p>)}
  </div>

  {
    kitaplar.length > 0 && (
      <div class="books-box">
        <div class="section-head">
          <h2>{t.yayinlanmisKitaplar}</h2>
          <a class="section-link" href="/en/kitaplar/">{t.tumunuGor}</a>
        </div>
        <ul class="books-list">
          {kitaplar.map((k) => (
            <li>
              <a class="book-title-link" href={`/en/kitaplar/${k.id}/`}>{k.data.title}</a>{' '}
              <span class="book-year">· {k.data.year}</span>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</BaseLayout>

<style>
  .bio-hero { display: flex; align-items: center; gap: 28px; margin-bottom: 2.25rem; }
  .avatar {
    width: 152px; height: 152px; flex-shrink: 0; border-radius: 50%;
    background: var(--surface-1); border: 0.5px solid var(--border);
    overflow: hidden;
  }
  .avatar :global(img) {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .bio-info { flex: 1; min-width: 0; }
  .bio-info h1 { font-size: 26px; line-height: 1.3; }
  .role-eyebrow { font-size: 13px; color: var(--text-secondary); margin: 8px 0 0; }
  .bio-body { font-size: 15px; color: var(--text-secondary); line-height: 1.75; margin-bottom: 2.25rem; }
  .bio-body p { margin-bottom: 1.1em; }
  .bio-body p:last-child { margin-bottom: 0; }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-link {
    font-size: 13px;
    color: var(--text-accent);
    text-decoration: none;
  }
  .books-box {
    margin-top: 2.5rem;
    background: var(--surface-1);
    border-radius: 12px;
    padding: 1.5rem 1.5rem 0.25rem;
  }
  .books-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .books-list li {
    padding: 12px 0;
    border-bottom: 0.5px solid var(--border);
    font-size: 14px;
    color: var(--text-primary);
    line-height: 1.6;
  }
  .books-list li:last-child {
    border-bottom: none;
  }
  .book-title-link {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
  }
  .book-title-link:hover {
    color: var(--text-accent);
    text-decoration: underline;
  }
  .book-year {
    color: var(--text-muted);
  }
  @media (max-width: 600px) {
    .bio-hero { flex-direction: column; }
    .avatar { width: 120px; height: 120px; }
  }
</style>
