---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BookCard from '../../../components/cards/BookCard.astro';
import Pills from '../../../components/navigation/Pills.astro';
import Pagination from '../../../components/navigation/Pagination.astro';
import { routes, type Locale } from '../../../i18n/routes';
import LangCountRow from '../../../components/metadata/LangCountRow.astro';
import { getContentCountsByLang } from '../../../lib/availability';
import { ui } from '../../../i18n/ui';

const lang = 'en';
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}
const t = ui[lang];

const KITAP_TURU_LABELS: Record<string, string> = {
  yazdıklarım: 'My Writing',
  editörlük: 'Edited',
  katkılar: 'Contributions',
};

const entries = (await getCollection('kitaplar', (e) => e.data.lang === lang)).sort(
  (a, b) => b.data.year - a.data.year,
);

const turCounts: Record<string, number> = {};
for (const e of entries) turCounts[e.data.kitapTuru] = (turCounts[e.data.kitapTuru] ?? 0) + 1;

const currentTip = Astro.url.searchParams.get('tip');
const pillItems = [
  { label: t.pillTumu, count: entries.length, href: '/en/kitaplar/', active: !currentTip },
  ...Object.entries(KITAP_TURU_LABELS)
    .filter(([tip]) => (turCounts[tip] ?? 0) > 0)
    .map(([tip, label]) => ({
      label,
      count: turCounts[tip] ?? 0,
      href: `/en/kitaplar/?tip=${tip}`,
      active: currentTip === tip,
    })),
];

const langCounts = await getContentCountsByLang();
const langItems = (['tr', 'en', 'de', 'fr'] as Locale[]).map((l) => ({
  lang: l,
  href: l === 'tr' ? '/kitaplar/' : `/${l}/kitaplar/`,
  count: langCounts[l].kitaplar,
}));
---

<BaseLayout
  lang={lang}
  title={t.navKitaplar}
  description={t.kitaplarAciklama}
  canonical="/en/kitaplar/"
  current="kitaplar"
  breadcrumb={[{ label: t.anaSayfa, href: routes.anaSayfa.en }, { label: t.navKitaplar }]}
>
  <h1>{t.navKitaplar}</h1>
  <p class="desc">{t.kitaplarAciklama}</p>

  <LangCountRow currentLang={lang} items={langItems} />

  <Pills items={pillItems} />

  <div class="book-grid">
    {
      entries.map((entry) => (
        <div class="card-wrap" data-tip={entry.data.kitapTuru}>
          <BookCard
            href={`/en/kitaplar/${entry.id}/`}
            cover={entry.data.kapak}
            coverAlt={entry.data.kapakAlt}
            title={entry.data.title}
            variant="grid"
            meta={String(entry.data.year)}
            seri={entry.data.seri}
          />
        </div>
      ))
    }
  </div>

  <Pagination currentPage={1} totalPages={1} basePath="/en/kitaplar/" />
</BaseLayout>

<style>
  .desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 520px;
    margin: 1rem 0 1.75rem;
  }
  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(148px, 1fr));
    gap: 22px 16px;
    margin-bottom: 1.75rem;
  }
  @media (max-width: 520px) {
    .book-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px 14px;
    }
  }
</style>

<script>
  const params = new URLSearchParams(location.search);
  const tip = params.get('tip');
  if (tip) {
    document.querySelectorAll<HTMLElement>('[data-tip]').forEach((card) => {
      card.style.display = card.dataset.tip === tip ? '' : 'none';
    });
    document.querySelectorAll<HTMLAnchorElement>('.pill').forEach((pill) => {
      const url = new URL(pill.href);
      pill.classList.toggle('active', url.searchParams.get('tip') === tip);
    });
  }
</script>
