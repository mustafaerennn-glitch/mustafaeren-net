---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PressList from '../../../components/navigation/PressList.astro';
import PressRow from '../../../components/navigation/PressRow.astro';
import Pills from '../../../components/navigation/Pills.astro';
import Pagination from '../../../components/navigation/Pagination.astro';
import { ALAN_LABELS_I18N } from '../../../lib/taxonomy';
import { getAreasForTopicRefs } from '../../../lib/taxonomy';
import { contentUrl, routes } from '../../../i18n/routes';
import { ui } from '../../../i18n/ui';

const lang = 'en';
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}
const t = ui[lang];

const entries = await getCollection('yazilar', (e) => e.data.lang === lang);
entries.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const rows = await Promise.all(
  entries.map(async (entry) => {
    const mecra = entry.data.mecra ? await getEntry(entry.data.mecra) : undefined;
    const areas = await getAreasForTopicRefs(entry.data.topics);
    return {
      href: contentUrl('yazilar', entry.data.lang, entry.id),
      title: entry.data.title,
      date: new Intl.DateTimeFormat(lang, { month: 'long', year: 'numeric' }).format(entry.data.publishDate),
      // Not: /mecra/{id}/ arşiv sayfaları yalnızca TR içeriğe referans veren mecralar için
      // üretiliyor (bkz. mecra/[slug].astro) — bu dilde link kırılmasın diye burada bilerek
      // tıklanamaz düz metin olarak gösteriliyor (mecra arşivinin kendisi henüz çok dilli değil).
      secondary: { label: mecra ? mecra.data.ad : 'Mustafaeren.net' },
      areas,
    };
  }),
);

const areaCounts: Record<string, number> = {};
for (const row of rows) {
  for (const a of row.areas) areaCounts[a] = (areaCounts[a] ?? 0) + 1;
}
const currentAlan = Astro.url.searchParams.get('alan');
const pillItems = [
  { label: t.pillTumu, count: rows.length, href: '/en/yazilar/', active: !currentAlan },
  ...Object.entries(ALAN_LABELS_I18N[lang]).map(([slug, label]) => ({
    label,
    count: areaCounts[slug] ?? 0,
    href: `/en/yazilar/?alan=${slug}`,
    active: currentAlan === slug,
  })),
];
---

<BaseLayout
  lang={lang}
  title={t.navYazilar}
  description={t.yazilarAciklama}
  canonical="/en/yazilar/"
  current="yazilar"
  breadcrumb={[{ label: t.anaSayfa, href: routes.anaSayfa.en }, { label: t.navYazilar }]}
>
  <h1>{t.navYazilar}</h1>
  <p class="desc">{t.yazilarAciklama}</p>

  <Pills items={pillItems} />

  <PressList>
    {
      rows.map((row) => (
        <div class="row-wrap" data-areas={row.areas.join(',')}>
          <PressRow href={row.href} title={row.title} date={row.date} secondary={row.secondary} />
        </div>
      ))
    }
  </PressList>

  <Pagination currentPage={1} totalPages={1} basePath="/en/yazilar/" />
</BaseLayout>

<style>
  .desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 520px;
    margin: 1rem 0 1.75rem;
  }
</style>

<script>
  const params = new URLSearchParams(location.search);
  const alan = params.get('alan');
  if (alan) {
    document.querySelectorAll<HTMLElement>('[data-areas]').forEach((row) => {
      const areas = row.dataset.areas?.split(',') ?? [];
      row.style.display = areas.includes(alan) ? '' : 'none';
    });
    document.querySelectorAll<HTMLAnchorElement>('.pill').forEach((pill) => {
      const url = new URL(pill.href);
      pill.classList.toggle('active', url.searchParams.get('alan') === alan);
    });
  }
</script>
