---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Pills from '../../../../components/navigation/Pills.astro';
import ContentListRow from '../../../../components/cards/ContentListRow.astro';
import Pagination from '../../../../components/navigation/Pagination.astro';
import { ALAN_LABELS_I18N, ALAN_SLUGS, getAreaCounts } from '../../../../lib/taxonomy';
import { TOPIC_LABELS_I18N } from '../../../../i18n/topics';
import { routes, type Locale } from '../../../../i18n/routes';
import LangCountRow from '../../../../components/metadata/LangCountRow.astro';
import { ui } from '../../../../i18n/ui';
import { TYPE_LABELS } from '../../../../lib/feed';
import { buildAlanHubItems, ALAN_TIP_QUERIES, type AlanHubItem, type AlanTipQuery } from '../../../../lib/alanHub';
import { paginateRows } from '../../../../lib/pressPagination';

const lang = 'fr';

export async function getStaticPaths() {
  return ALAN_SLUGS.map((alan) => ({ params: { alan } }));
}

const { alan } = Astro.params;
const t = ui[lang];
const alanLabel = ALAN_LABELS_I18N[lang][alan as string];
const typeLabels = TYPE_LABELS[lang];

const items = await buildAlanHubItems(alan as string, lang);
const { pageRows: rows, totalPages } = paginateRows(items, 1);

const topicCounts = new Map<string, number>();
for (const item of items) topicCounts.set(item.topicId, (topicCounts.get(item.topicId) ?? 0) + 1);
const maxTopicCount = Math.max(1, ...topicCounts.values());

const topics = await getCollection('topics');
const topicsInAlan = topics.filter((tp) => tp.data.alan === alan);
const topicsWithCounts = topicsInAlan
  .map((tp) => ({ id: tp.id, label: TOPIC_LABELS_I18N[lang][tp.id] ?? tp.data.ad, count: topicCounts.get(tp.id) ?? 0 }))
  .filter((tp) => tp.count > 0)
  .sort((a, b) => b.count - a.count);

const tipCounts: Record<AlanHubItem['tip'], number> = { Yazı: 0, Basında: 0, Video: 0, Kitap: 0 };
for (const item of items) tipCounts[item.tip]++;

const TIP_LABEL: Record<AlanTipQuery, string> = { yazi: t.navYazilar, video: t.navVideolar, kitap: t.navKitaplar, basinda: t.pillSoylesiler };
const TIP_COUNT_KEY: Record<AlanTipQuery, AlanHubItem['tip']> = { yazi: 'Yazı', video: 'Video', kitap: 'Kitap', basinda: 'Basında' };
const pillItems = [
  { label: t.pillTumu, count: items.length, href: `/fr/alanlar/${alan}/`, active: true },
  ...ALAN_TIP_QUERIES.map((tq) => ({
    label: TIP_LABEL[tq],
    count: tipCounts[TIP_COUNT_KEY[tq]],
    href: `/fr/alanlar/${alan}/tip/${tq}/`,
    active: false,
  })),
];

const mecraCounts = new Map<string, number>();
for (const item of items) {
  if (item.mecraId) mecraCounts.set(item.mecraId, (mecraCounts.get(item.mecraId) ?? 0) + 1);
}
const mecraEntries = (
  await Promise.all([...mecraCounts.entries()].map(async ([id, count]) => ({ mecra: await getEntry('mecralar', id), count })))
).filter((e): e is { mecra: NonNullable<typeof e.mecra>; count: number } => Boolean(e.mecra));

const LOCALES: Locale[] = ['tr', 'en', 'de', 'fr'];
const areaCountsByLang = await Promise.all(LOCALES.map((l) => getAreaCounts(l)));
const langItems = LOCALES.map((l, i) => ({
  lang: l,
  href: l === 'tr' ? `/alanlar/${alan}/` : `/${l}/alanlar/${alan}/`,
  count: areaCountsByLang[i][alan as string] ?? 0,
}));
---

<BaseLayout
  lang={lang}
  title={alanLabel}
  description={`${alanLabel} : ${topicsWithCounts.length} sujets.`}
  canonical={`/fr/alanlar/${alan}/`}
  current="konular"
  breadcrumb={[{ label: t.anaSayfa, href: routes.anaSayfa.fr }, { label: t.navKonular, href: '/fr/konu/' }, { label: alanLabel }]}
>
  <p class="eyebrow">{t.arastirmaAlaniEyebrow}</p>
  <h1>{alanLabel}</h1>
  <p class="meta-line">{items.length} {items.length === 1 ? t.icerikSayisiTekil : t.icerikSayisiCogul} · {topicsWithCounts.length} {t.navKonular.toLowerCase()}</p>

  <LangCountRow currentLang={lang} items={langItems} />

  {
    topicsWithCounts.length > 0 && (
      <div class="topics-section">
        <p class="section-label">{t.buAlandakiKonular}</p>
        <div class="topics-grid">
          {topicsWithCounts.map((tp) => (
            <a class="topic-card" href={`/fr/konu/${tp.id}/`}>
              <span class="topic-name">{tp.label}</span>
              <span class="topic-count">{tp.count} {tp.count === 1 ? t.icerikSayisiTekil : t.icerikSayisiCogul}</span>
              <span class="topic-bar"><span class="topic-bar-fill" style={`width:${Math.round((tp.count / maxTopicCount) * 100)}%`} /></span>
            </a>
          ))}
        </div>
      </div>
    )
  }

  <div class="feed-head">
    <h2>{t.alandakiTumIcerik}</h2>
    <span class="feed-note">{t.kronolojikNot}</span>
  </div>

  <Pills items={pillItems} />

  <div class="content-list">
    {
      rows.map((item) => (
        <ContentListRow
          date={item.tip === 'Kitap' ? String(item.date.getFullYear()) : new Intl.DateTimeFormat(lang, { month: 'short', year: 'numeric' }).format(item.date)}
          badge={typeLabels[item.tip]}
          title={item.title}
          href={item.href}
          topicBadge={TOPIC_LABELS_I18N[lang][item.topicId]}
        />
      ))
    }
  </div>

  <Pagination currentPage={1} totalPages={totalPages} basePath={`/fr/alanlar/${alan}/`} />

  {
    mecraEntries.length > 0 && (
      <div class="mecra-section">
        <p class="section-label">{t.yayinlandigiMecralar}</p>
        <div class="mecra-pills">
          {mecraEntries.map(({ mecra, count }) => (
            <span class="mecra-pill">{mecra.data.ad} · {count}</span>
          ))}
        </div>
      </div>
    )
  }
</BaseLayout>

<style>
  .eyebrow {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }
  .meta-line {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }
  .topics-section {
    margin-bottom: 2.5rem;
  }
  .section-label {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 12px;
  }
  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 10px;
  }
  .topic-card {
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .topic-name {
    font-size: 14px;
    font-weight: 500;
  }
  .topic-count {
    font-size: 12px;
    color: var(--text-muted);
  }
  .topic-bar {
    height: 3px;
    border-radius: 2px;
    background: var(--surface-1);
    overflow: hidden;
    display: block;
  }
  .topic-bar-fill {
    height: 100%;
    background: var(--text-accent);
    opacity: 0.55;
    display: block;
  }
  .feed-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .feed-head h2 {
    font-size: 15px;
  }
  .feed-note {
    font-size: 12px;
    color: var(--text-muted);
  }
  .content-list {
    border-top: 0.5px solid var(--border);
    margin-bottom: 1.5rem;
  }
  .mecra-section {
    border-top: 0.5px solid var(--border);
    padding-top: 1.5rem;
    margin-bottom: 2rem;
  }
  .mecra-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .mecra-pill {
    font-size: 13px;
    padding: 5px 10px;
    border-radius: 999px;
    background: var(--surface-1);
    color: var(--text-secondary);
  }
</style>
