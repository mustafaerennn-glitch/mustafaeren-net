---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { routes, type Locale } from '../../i18n/routes';
import { ui } from '../../i18n/ui';

const lang = 'fr';
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}

const t = ui[lang];
const alternates = (Object.entries(routes.iletisim) as [Locale, string][]).map(([l, href]) => ({ lang: l, href }));
---

<BaseLayout
  lang={lang}
  title={t.navIletisim}
  description={t.iletisimAciklama}
  canonical={routes.iletisim.fr}
  alternates={alternates}
  showLangSwitcher
  current="iletisim"
  breadcrumb={[{ label: t.anaSayfa, href: routes.anaSayfa.fr }, { label: t.navIletisim }]}
>
  <h1>{t.navIletisim}</h1>
  <p class="desc">{t.iletisimAciklama}</p>
  <a class="btn-secondary" href="mailto:info@mustafaeren.net">
    <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
    info@mustafaeren.net
  </a>

  <form class="contact-form" name="iletisim" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/fr/contact/merci/">
    <input type="hidden" name="form-name" value="iletisim" />
    <p hidden>
      <label>{t.iletisimBotUyari} <input name="bot-field" /></label>
    </p>
    <div class="field">
      <label for="name">{t.iletisimIsim}</label>
      <input type="text" id="name" name="name" autocomplete="name" required />
    </div>
    <div class="field">
      <label for="email">{t.iletisimEposta}</label>
      <input type="email" id="email" name="email" autocomplete="email" required />
    </div>
    <div class="field">
      <label for="message">{t.iletisimMesaj}</label>
      <textarea id="message" name="message" required></textarea>
    </div>
    <button type="submit" class="submit-btn">{t.iletisimGonder}</button>
  </form>
  <p class="privacy-note">{t.iletisimGizlilikNotu}</p>
</BaseLayout>

<style>
  .desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 1rem 0 1.5rem;
  }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    font-family: var(--font-sans);
    border-radius: var(--radius);
    padding: 9px 16px;
    cursor: pointer;
    border: 0.5px solid var(--border);
    background: transparent;
    color: var(--text-primary);
    text-decoration: none;
    margin-bottom: 2.25rem;
  }
  .btn-secondary:hover {
    border-color: var(--text-accent);
    color: var(--text-accent);
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 480px;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .field label {
    font-size: 13px;
    color: var(--text-secondary);
    padding-left: 12px;
  }
  .field input,
  .field textarea {
    font-family: var(--font-sans);
    font-size: 14.5px;
    color: var(--text-primary);
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 12px;
    resize: vertical;
  }
  .field input:focus,
  .field textarea:focus {
    outline: 2px solid rgba(24, 95, 165, 0.25);
    outline-offset: 2px;
    border-color: var(--text-accent);
  }
  .field textarea {
    min-height: 120px;
  }
  .privacy-note {
    font-size: 12.5px;
    color: var(--text-muted);
    margin-top: 0.9rem;
    max-width: 480px;
  }
  .submit-btn {
    align-self: flex-start;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    background: var(--fill-primary);
    color: var(--on-primary);
    border: none;
    padding: 10px 22px;
    border-radius: var(--radius);
    cursor: pointer;
  }
  .submit-btn:hover {
    opacity: 0.9;
  }
</style>
