---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/cards/BookCard.astro';
import { getAreaCounts, ALAN_LABELS, ALAN_LABELS_I18N } from '../../lib/taxonomy';
import { getMergedFeed } from '../../lib/feed';
import { routes, type Locale } from '../../i18n/routes';
import { ui } from '../../i18n/ui';
import profilFoto from '../../assets/profil-fotografi.jpg';

const lang = 'fr';
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}

const t = ui[lang];
const alternates = (Object.entries(routes.hakkimda) as [Locale, string][]).map(([l, href]) => ({ lang: l, href }));

const bio =
  "Sociologue et chercheur travaillant sur les politiques carcérales, la migration, les droits humains et l'histoire politique récente — écrivant et développant des archives numériques.";

// TR ana sayfayla aynı SVG ikon seti (kullanıcı onaylı) — yalnızca metin çevrildi, görsel dil aynı.
const AREA_ICONS: Record<string, string> = {
  hapishane:
    '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="1"/><line x1="7.5" y1="4" x2="7.5" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/><line x1="16.5" y1="4" x2="16.5" y2="20"/></svg>',
  'siyasi-tarih':
    '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 10l10-6 10 6"/><path d="M4 10v11"/><path d="M20 10v11"/><path d="M2 21h20"/><line x1="8" y1="13" x2="8" y2="18"/><line x1="12" y1="13" x2="12" y2="18"/><line x1="16" y1="13" x2="16" y2="18"/></svg>',
  goc: '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="7" width="14" height="14" rx="2"/><path d="M9 7V4.5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1V7"/><line x1="9" y1="10" x2="9" y2="18"/><line x1="15" y1="10" x2="15" y2="18"/><line x1="7.5" y1="21" x2="7.5" y2="22.5"/><line x1="16.5" y1="21" x2="16.5" y2="22.5"/></svg>',
  emek: '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 0 0-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 0 0-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 0 0-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 0 0-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 0 0 1.066-2.573c-.94-1.543.826-3.31 2.37-2.37c1 .608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>',
};

// TR ana sayfayla aynı kural: "Diğer" gösterilmiyor (kullanıcı kararı). Kart ETİKETİ çevrilir,
// link hedefi TR Alan Hub sayfasına gider — o sayfalar henüz çok dilli değil (bkz. taxonomy.ts).
const areaCounts = await getAreaCounts(lang);
const areas = Object.entries(ALAN_LABELS)
  .filter(([slug]) => slug !== 'diger')
  .map(([slug]) => ({
    slug,
    label: ALAN_LABELS_I18N[lang][slug],
    count: areaCounts[slug] ?? 0,
    icon: AREA_ICONS[slug],
  }));

const feed = await getMergedFeed(5, lang);

// Kitaplar koleksiyonunda şu an FR girdi yok (yalnızca TR yayınlar var) — bölüm bu yüzden
// TR ana sayfadaki gibi koşullu, sahte/boş kitap kartı üretilmiyor.
const kitaplar = (await getCollection('kitaplar', (e) => e.data.lang === lang && e.data.kitapTuru === 'yazdıklarım')).slice(0, 5);
---

<BaseLayout
  lang={lang}
  title="Mustafa Eren"
  description={bio}
  canonical={routes.anaSayfa.fr}
  alternates={alternates}
  showLangSwitcher
>
  <section class="hero">
    <div class="hero-text">
      <p class="eyebrow">{t.anaSayfaEyebrow}</p>
      <h1>Mustafa Eren</h1>
      <p class="bio">{bio}</p>
      <div class="cta-row">
        <a class="btn-primary" href="/yazilar/">{t.anaSayfaCtaYazilar}</a>
        <a class="btn-secondary" href={routes.hakkimda.fr}>{t.hakkimdaBaslik}</a>
      </div>
    </div>
    <div class="avatar">
      <Image src={profilFoto} alt="Mustafa Eren" width={256} height={256} />
    </div>
  </section>

  <section class="section" style="margin-bottom: 2rem;">
    <div class="project-card">
      <div>
        <p class="project-label">{t.projeEtiket}</p>
        <p class="project-name">Kanlı Pazar</p>
        <p class="project-desc">{t.projeAciklama}</p>
      </div>
      <a class="section-link" href="https://kanlipazar.net" target="_blank" rel="noopener">{t.projeLink}</a>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>{t.arastirmaAlanlari}</h2>
      <a class="section-link" href="/konu/">{t.tumunuGor}</a>
    </div>
    <div class="areas-grid">
      {
        areas.map((area) => (
          <a class="area-card" href={`/alanlar/${area.slug}/`}>
            <div class="area-icon" set:html={area.icon} />
            <p class="area-name">{area.label}</p>
            <p class="area-count">{area.count} {area.count === 1 ? t.icerikSayisiTekil : t.icerikSayisiCogul}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>{t.sonEklenenler}</h2>
      <a class="section-link" href="/yazilar/">{t.tumunuGor}</a>
    </div>
    <div>
      {
        feed.map((item) => (
          <div class="feed-row">
            <span class="feed-type">{item.typeLabel}</span>
            <a class="feed-title" href={item.href}>
              {item.title}
              {item.meta && <span class="meta"> · {item.meta}</span>}
            </a>
            <span class="feed-date">{item.dateLabel}</span>
          </div>
        ))
      }
    </div>
  </section>

  {
    kitaplar.length > 0 && (
      <section class="section" style="margin-bottom: 2rem;">
        <div class="section-head">
          <h2>{t.navKitaplar}</h2>
          <a class="section-link" href="/kitaplar/">{t.tumunuGor}</a>
        </div>
        <div class="books-grid">
          {kitaplar.map((k) => (
            <BookCard href={`/kitaplar/${k.id}/`} cover={k.data.kapak} coverAlt={k.data.kapakAlt} title={k.data.title} variant="compact" />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .hero {
    padding: 1rem 0 2.5rem;
    border-bottom: 0.5px solid var(--border);
    margin-bottom: 2.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }
  .hero-text {
    flex: 1;
    min-width: 0;
  }
  .eyebrow {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }
  .hero h1 {
    font-size: 28px;
    margin-bottom: 12px;
  }
  .bio {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 440px;
    margin-bottom: 20px;
  }
  .cta-row {
    display: flex;
    gap: 10px;
  }
  .btn-primary,
  .btn-secondary {
    font-size: 13px;
    font-family: var(--font-sans);
    border-radius: var(--radius);
    padding: 8px 16px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }
  .btn-primary {
    background: var(--fill-primary);
    color: var(--on-primary);
    border: none;
  }
  .btn-secondary {
    background: transparent;
    border: 0.5px solid var(--border);
    color: var(--text-primary);
  }
  .avatar {
    width: 128px;
    height: 128px;
    border-radius: 50%;
    background: var(--surface-1);
    flex-shrink: 0;
    overflow: hidden;
  }
  .avatar :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .section {
    margin-bottom: 2.5rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-link {
    font-size: 13px;
    color: var(--text-accent);
    text-decoration: none;
  }
  .project-card {
    background: var(--surface-1);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .project-label {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 4px;
  }
  .project-name {
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .project-desc {
    font-size: 13px;
    color: var(--text-secondary);
  }
  .areas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
  }
  .area-card {
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem 1rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .area-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
  }
  .area-name {
    font-size: 13px;
    font-weight: 500;
    margin: 10px 0 2px;
  }
  .area-count {
    font-size: 12px;
    color: var(--text-muted);
  }
  .feed-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 12px 0;
    border-bottom: 0.5px solid var(--border);
  }
  .feed-row:last-child {
    border-bottom: none;
  }
  .feed-type {
    font-size: 11px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: var(--radius);
    background: var(--surface-1);
    color: var(--text-secondary);
    white-space: nowrap;
  }
  .feed-title {
    flex: 1;
    min-width: 0;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
  }
  .feed-title:hover {
    color: var(--text-accent);
  }
  .feed-title .meta {
    font-weight: 400;
    color: var(--text-muted);
  }
  .feed-date {
    font-size: 12px;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(112px, 1fr));
    gap: 14px;
  }
</style>
