---
import { getCollection } from 'astro:content';
import KitapDetaySayfasi from '../../../components/content/KitapDetaySayfasi.astro';

export async function getStaticPaths() {
  const entries = await getCollection('kitaplar', (entry) => entry.data.lang === 'fr');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
---

<KitapDetaySayfasi entry={entry} />
