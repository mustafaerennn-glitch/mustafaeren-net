---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import BookCard from '../../../../../components/cards/BookCard.astro';
import Pills from '../../../../../components/navigation/Pills.astro';
import Pagination from '../../../../../components/navigation/Pagination.astro';
import { routes, type Locale } from '../../../../../i18n/routes';
import LangCountRow from '../../../../../components/metadata/LangCountRow.astro';
import { getContentCountsByLang } from '../../../../../lib/availability';
import { ui } from '../../../../../i18n/ui';
import {
  buildKitaplarEntries,
  KITAP_TURU_SLUGS,
  KITAP_TURU_BY_SLUG,
  KITAP_TURU_LABELS_I18N,
} from '../../../../../lib/kitaplar';
import { paginateRows } from '../../../../../lib/pressPagination';

export async function getStaticPaths() {
  return Object.values(KITAP_TURU_SLUGS).map((tip) => ({ params: { tip } }));
}

const lang = 'fr';
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}
const t = ui[lang];

const tipSlug = Astro.params.tip as string;
const currentTur = KITAP_TURU_BY_SLUG[tipSlug];
const allEntries = await buildKitaplarEntries(lang);
const turEntries = allEntries.filter((e) => e.data.kitapTuru === currentTur);
const { pageRows: pageEntries, totalPages } = paginateRows(turEntries, 1);

const turCounts: Record<string, number> = {};
for (const e of allEntries) turCounts[e.data.kitapTuru] = (turCounts[e.data.kitapTuru] ?? 0) + 1;

const turuLabels = KITAP_TURU_LABELS_I18N[lang];
const pillItems = [
  { label: t.pillTumu, count: allEntries.length, href: '/fr/kitaplar/', active: false },
  ...Object.entries(turuLabels)
    .filter(([tur]) => (turCounts[tur] ?? 0) > 0)
    .map(([tur, label]) => ({
      label,
      count: turCounts[tur] ?? 0,
      href: `/fr/kitaplar/tip/${KITAP_TURU_SLUGS[tur]}/`,
      active: tur === currentTur,
    })),
];

const langCounts = await getContentCountsByLang();
const langItems = (['tr', 'en', 'de', 'fr'] as Locale[]).map((l) => ({
  lang: l,
  href: l === 'tr' ? '/kitaplar/' : `/${l}/kitaplar/`,
  count: langCounts[l].kitaplar,
}));

const turLabel = turuLabels[currentTur];
---

<BaseLayout
  lang={lang}
  title={`${t.navKitaplar} — ${turLabel}`}
  description={t.kitaplarAciklama}
  canonical={`/fr/kitaplar/tip/${tipSlug}/`}
  current="kitaplar"
  breadcrumb={[
    { label: t.anaSayfa, href: routes.anaSayfa.fr },
    { label: t.navKitaplar, href: '/fr/kitaplar/' },
    { label: turLabel },
  ]}
>
  <h1>{t.navKitaplar}</h1>
  <p class="desc">{t.kitaplarAciklama}</p>

  <LangCountRow currentLang={lang} items={langItems} />

  <Pills items={pillItems} />

  {
    turEntries.length === 0 ? (
      <p class="empty-note">{t.bosIcerikMesaji}</p>
    ) : (
      <>
        <div class="book-grid">
          {pageEntries.map((entry) => (
            <BookCard
              href={`/fr/kitaplar/${entry.id}/`}
              cover={entry.data.kapak}
              coverAlt={entry.data.kapakAlt}
              title={entry.data.title}
              variant="grid"
              meta={String(entry.data.year)}
              seri={entry.data.seri}
            />
          ))}
        </div>

        <Pagination currentPage={1} totalPages={totalPages} basePath={`/fr/kitaplar/tip/${tipSlug}/`} />
      </>
    )
  }
</BaseLayout>

<style>
  .desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 520px;
    margin: 1rem 0 1.75rem;
  }
  .empty-note {
    font-size: 14px;
    color: var(--text-muted);
  }
  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(148px, 1fr));
    gap: 22px 16px;
    margin-bottom: 1.75rem;
  }
  @media (max-width: 520px) {
    .book-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px 14px;
    }
  }
</style>
