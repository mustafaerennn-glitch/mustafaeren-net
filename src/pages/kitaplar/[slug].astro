---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicsRow from '../../components/metadata/TopicsRow.astro';
import AboutModal from '../../components/content/AboutModal.astro';
import BookCard from '../../components/cards/BookCard.astro';
import { getAreasForTopicRefs, getTopicsMap, ALAN_LABELS } from '../../lib/taxonomy';

export async function getStaticPaths() {
  const entries = await getCollection('kitaplar', (entry) => entry.data.lang === 'tr');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
if (Astro.currentLocale !== 'tr') {
  throw new Error(`i18n locale eşleşmedi: beklenen "tr", Astro.currentLocale="${Astro.currentLocale}"`);
}

const canonical = `/kitaplar/${entry.id}/`;

const KITAP_TURU_ROL: Record<string, string> = {
  yazdıklarım: 'Yazar',
  editörlük: 'Editör',
  katkılar: 'Katkı yazarı',
};
const KITAP_TURU_BADGE: Record<string, string> = {
  yazdıklarım: 'Yazdıklarım',
  editörlük: 'Editörlük',
  katkılar: 'Katkılar',
};

const areaSlugs = await getAreasForTopicRefs(entry.data.topics);
const topicsMap = await getTopicsMap();
const topics = entry.data.topics
  .map((ref) => topicsMap.get(ref.id))
  .filter((t): t is NonNullable<typeof t> => Boolean(t))
  .map((t) => ({ slug: t.id, label: t.data.ad }));
const areas = areaSlugs.map((slug) => ({ slug, label: ALAN_LABELS[slug] }));

const others = (await getCollection('kitaplar', (e) => e.data.lang === 'tr' && e.id !== entry.id)).slice(0, 4);
---

<BaseLayout
  lang={entry.data.lang}
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  current="kitaplar"
  breadcrumb={[{ label: 'Ana sayfa', href: '/' }, { label: 'Kitaplar', href: '/kitaplar/' }, { label: entry.data.title }]}
>
  <div class="book-hero">
    <div class="cover">
      <Image src={entry.data.kapak} alt={entry.data.kapakAlt} width={300} />
    </div>
    <div class="book-info">
      <p class="role-eyebrow">{KITAP_TURU_ROL[entry.data.kitapTuru]}</p>
      <h1>{entry.data.title}</h1>
      <p class="book-meta-line">{entry.data.year} · {entry.data.yayinevi} · {entry.data.sayfaSayisi} sayfa</p>
      <div class="badges">
        <span class="badge">{KITAP_TURU_BADGE[entry.data.kitapTuru]}</span>
        {entry.data.seri && <span class="badge seri">{entry.data.seri}</span>}
      </div>
      <div class="cta-row">
        {entry.data.pdf && <a class="btn-primary" href={entry.data.pdf}>PDF'yi oku</a>}
        {entry.data.yayineviUrl && (
          <a class="btn-secondary" href={entry.data.yayineviUrl} target="_blank" rel="noopener">Yayınevi sayfası</a>
        )}
        <AboutModal
          id="about-modal"
          triggerLabel="Kitap hakkında"
          title={entry.data.title}
          metaLine={`${KITAP_TURU_ROL[entry.data.kitapTuru]} · ${entry.data.yayinevi} · ${entry.data.year} · ${entry.data.sayfaSayisi} sayfa`}
        >
          <p>{entry.data.description}</p>
        </AboutModal>
      </div>
    </div>
  </div>

  <p class="short-desc">{entry.data.description}</p>

  <TopicsRow areas={areas} topics={topics} />

  {
    others.length > 0 && (
      <div class="section" style="margin-bottom: 0;">
        <div class="section-head">
          <h2>Diğer kitaplar</h2>
          <a class="section-link" href="/kitaplar/">Tümünü gör</a>
        </div>
        <div class="other-books-grid">
          {others.map((o) => (
            <BookCard href={`/kitaplar/${o.id}/`} cover={o.data.kapak} coverAlt={o.data.kapakAlt} title={o.data.title} variant="detail" meta={`${KITAP_TURU_ROL[o.data.kitapTuru]} · ${o.data.year}`} />
          ))}
        </div>
      </div>
    )
  }
</BaseLayout>

<style>
  h1 {
    font-size: 26px;
    line-height: 1.3;
  }
  .book-hero {
    display: flex;
    gap: 28px;
    margin-bottom: 1.75rem;
  }
  .cover {
    width: 168px;
    aspect-ratio: 2 / 3;
    flex-shrink: 0;
    border-radius: 6px;
    background: var(--surface-1);
    border: 0.5px solid var(--border);
    overflow: hidden;
  }
  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .book-info {
    flex: 1;
    min-width: 0;
    padding-top: 4px;
  }
  .role-eyebrow {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }
  .book-meta-line {
    font-size: 13px;
    color: var(--text-secondary);
    margin: 10px 0 14px;
    line-height: 1.6;
  }
  .badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .badge {
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 999px;
    border: 0.5px solid var(--border);
    color: var(--text-secondary);
  }
  .badge.seri {
    color: var(--text-muted);
    background: none;
    border-style: dashed;
  }
  .cta-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .btn-primary,
  .btn-secondary {
    font-size: 13px;
    font-family: var(--font-sans);
    border-radius: var(--radius);
    padding: 9px 18px;
    cursor: pointer;
    border: none;
    text-decoration: none;
    display: inline-block;
  }
  .btn-primary {
    background: var(--fill-primary);
    color: var(--on-primary);
  }
  .btn-secondary {
    background: transparent;
    border: 0.5px solid var(--border);
    color: var(--text-primary);
  }
  .short-desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 520px;
    margin: 0 0 1.75rem;
  }
  .section {
    margin-bottom: 2.25rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-link {
    font-size: 13px;
    color: var(--text-accent);
    text-decoration: none;
  }
  .other-books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(112px, 1fr));
    gap: 14px;
  }
  @media (max-width: 600px) {
    .book-hero {
      flex-direction: column;
    }
    .cover {
      width: 150px;
    }
  }
</style>
