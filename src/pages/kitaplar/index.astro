---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/cards/BookCard.astro';
import Pills from '../../components/navigation/Pills.astro';
import Pagination from '../../components/navigation/Pagination.astro';
import LangCountRow from '../../components/metadata/LangCountRow.astro';
import { getContentCountsByLang } from '../../lib/availability';
import type { Locale } from '../../i18n/routes';
import { buildKitaplarEntries, kitapHref, KITAP_TURU_SLUGS, KITAP_TURU_LABELS_I18N } from '../../lib/kitaplar';
import { paginateRows } from '../../lib/pressPagination';

const lang = 'tr';
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}

const entries = await buildKitaplarEntries(lang);
const { pageRows: pageEntries, totalPages } = paginateRows(entries, 1);

const turCounts: Record<string, number> = {};
for (const e of entries) turCounts[e.data.kitapTuru] = (turCounts[e.data.kitapTuru] ?? 0) + 1;

const turuLabels = KITAP_TURU_LABELS_I18N[lang];
const pillItems = [
  { label: 'Tümü', count: entries.length, href: '/kitaplar/', active: true },
  ...Object.entries(turuLabels)
    .filter(([tur]) => (turCounts[tur] ?? 0) > 0)
    .map(([tur, label]) => ({
      label,
      count: turCounts[tur] ?? 0,
      href: `/kitaplar/tip/${KITAP_TURU_SLUGS[tur]}/`,
      active: false,
    })),
];

const langCounts = await getContentCountsByLang();
const langItems = (['tr', 'en', 'de', 'fr'] as Locale[]).map((l) => ({
  lang: l,
  href: l === 'tr' ? '/kitaplar/' : `/${l}/kitaplar/`,
  count: langCounts[l].kitaplar,
}));
---

<BaseLayout
  lang={lang}
  title="Kitaplar"
  description="Yazdığım ve editörlüğünü üstlendiğim kitaplar, ayrıca bir bölümüyle katkıda bulunduğum derlemeler — hapishane çalışmaları, göç ve yakın siyasal tarih üzerine."
  canonical="/kitaplar/"
  current="kitaplar"
  breadcrumb={[{ label: 'Ana sayfa', href: '/' }, { label: 'Kitaplar' }]}
>
  <h1>Kitaplar</h1>
  <p class="desc">Yazdığım ve editörlüğünü üstlendiğim kitaplar, ayrıca bir bölümüyle katkıda bulunduğum derlemeler — hapishane çalışmaları, göç ve yakın siyasal tarih üzerine.</p>

  <LangCountRow currentLang={lang} items={langItems} />

  <Pills items={pillItems} />

  <div class="book-grid">
    {
      pageEntries.map((entry) => (
        <BookCard
          href={kitapHref(entry)}
          cover={entry.data.kapak}
          coverAlt={entry.data.kapakAlt}
          title={entry.data.title}
          variant="grid"
          meta={String(entry.data.year)}
          seri={entry.data.seri}
        />
      ))
    }
  </div>

  <Pagination currentPage={1} totalPages={totalPages} basePath="/kitaplar/" />
</BaseLayout>

<style>
  .desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 520px;
    margin: 1rem 0 1.75rem;
  }
  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(148px, 1fr));
    gap: 22px 16px;
    margin-bottom: 1.75rem;
  }
  @media (max-width: 520px) {
    .book-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px 14px;
    }
  }
</style>
