---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicsRow from '../../components/metadata/TopicsRow.astro';
import AboutModal from '../../components/content/AboutModal.astro';
import VideoCard from '../../components/cards/VideoCard.astro';
import { contentUrl } from '../../i18n/routes';
import { formatDuration } from '../../lib/format';
import { getAreasForTopicRefs, getTopicsMap, ALAN_LABELS } from '../../lib/taxonomy';

export async function getStaticPaths() {
  const entries = await getCollection('videolar', (entry) => entry.data.lang === 'tr');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
if (Astro.currentLocale !== 'tr') {
  throw new Error(`i18n locale eşleşmedi: beklenen "tr", Astro.currentLocale="${Astro.currentLocale}"`);
}

const canonical = contentUrl('videolar', entry.data.lang, entry.id);
const mecra = entry.data.mecra ? await getEntry(entry.data.mecra) : undefined;
const dateLabel = new Intl.DateTimeFormat(entry.data.lang, { day: 'numeric', month: 'long', year: 'numeric' }).format(entry.data.publishDate);
const duration = formatDuration(entry.data.durationMinutes, entry.data.lang);

const VIDEO_TURU_LABELS: Record<string, string> = {
  söyleşi: 'Söyleşi',
  belgesel: 'Belgesel',
  'konferans-panel': 'Konferans / Panel',
  'kısa-video': 'Kısa videolar',
};

const areaSlug = (await getAreasForTopicRefs(entry.data.topics))[0];
const topicsMap = await getTopicsMap();
const topics = entry.data.topics
  .map((ref) => topicsMap.get(ref.id))
  .filter((t): t is NonNullable<typeof t> => Boolean(t))
  .map((t) => ({ slug: t.id, label: t.data.ad }));
const areas = areaSlug ? [{ slug: areaSlug, label: ALAN_LABELS[areaSlug] }] : [];

const others = (await getCollection('videolar', (e) => e.data.lang === 'tr' && e.id !== entry.id))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 2);
const otherCards = await Promise.all(
  others.map(async (o) => {
    const oMecra = o.data.mecra ? await getEntry(o.data.mecra) : undefined;
    return {
      href: contentUrl('videolar', o.data.lang, o.id),
      thumbnail: o.data.thumbnail,
      thumbnailAlt: o.data.thumbnailAlt,
      title: o.data.title,
      typeBadge: VIDEO_TURU_LABELS[o.data.videoTuru],
      sourceText: `${oMecra ? oMecra.data.ad : 'Mustafaeren.net'} · ${o.data.publishDate.getFullYear()}`,
      duration: formatDuration(o.data.durationMinutes, o.data.lang),
    };
  }),
);
---

<BaseLayout
  lang={entry.data.lang}
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  current="videolar"
  breadcrumb={[{ label: 'Ana sayfa', href: '/' }, { label: 'Videolar', href: '/videolar/' }, { label: entry.data.title }]}
  pageWidth="760px"
>
  <div class="embed" data-embed-url={entry.data.embedUrl}>
    <button type="button" class="play-badge" aria-label="Videoyu oynat">
      <svg width="52" height="52" viewBox="0 0 52 52"><circle cx="26" cy="26" r="25" fill="none" stroke="#fff" stroke-width="1.6"/><path d="M20 15l19 11-19 11z" fill="#fff"/></svg>
    </button>
  </div>

  <p class="role-eyebrow">{VIDEO_TURU_LABELS[entry.data.videoTuru]}</p>
  <h1>{entry.data.title}</h1>
  <p class="video-meta-line">{dateLabel} · {mecra ? mecra.data.ad : 'Mustafaeren.net'} · {duration}</p>

  <div class="cta-row">
    <a class="btn-secondary" href={entry.data.embedUrl} target="_blank" rel="noopener">YouTube'da izle</a>
    <AboutModal id="about-modal" triggerLabel="Video hakkında" title={entry.data.title} metaLine={`${VIDEO_TURU_LABELS[entry.data.videoTuru]} · ${mecra ? mecra.data.ad : 'Mustafaeren.net'} · ${dateLabel} · ${duration}`}>
      <p>{entry.data.description}</p>
    </AboutModal>
  </div>

  <p class="short-desc">{entry.data.description}</p>

  <TopicsRow areas={areas} topics={topics} />

  {
    otherCards.length > 0 && (
      <div class="section">
        <div class="section-head">
          <h2>Diğer videolar</h2>
          <a class="section-link" href="/videolar/">Tümünü gör</a>
        </div>
        <div class="video-grid">
          {otherCards.map((c) => (
            <VideoCard href={c.href} thumbnail={c.thumbnail} thumbnailAlt={c.thumbnailAlt} title={c.title} typeBadge={c.typeBadge} sourceText={c.sourceText} duration={c.duration} />
          ))}
        </div>
      </div>
    )
  }
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>('.embed[data-embed-url]').forEach((container) => {
    container.querySelector('.play-badge')?.addEventListener('click', () => {
      const url = container.dataset.embedUrl;
      if (!url) return;
      const iframe = document.createElement('iframe');
      iframe.src = url;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'width:100%;height:100%;border:0;';
      container.replaceChildren(iframe);
    });
  });
</script>

<style>
  h1 {
    font-size: 24px;
    line-height: 1.35;
  }
  .embed {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    background: var(--surface-1);
    border: 0.5px solid var(--border);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .play-badge {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.3));
  }
  .role-eyebrow {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }
  .video-meta-line {
    font-size: 13px;
    color: var(--text-secondary);
    margin: 10px 0 14px;
    line-height: 1.6;
  }
  .cta-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }
  .btn-secondary {
    font-size: 13px;
    font-family: var(--font-sans);
    border-radius: var(--radius);
    padding: 9px 18px;
    cursor: pointer;
    border: 0.5px solid var(--border);
    color: var(--text-primary);
    background: transparent;
    text-decoration: none;
    display: inline-block;
  }
  .short-desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 520px;
    margin: 0 0 1.75rem;
  }
  .section {
    margin-bottom: 2.25rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-link {
    font-size: 13px;
    color: var(--text-accent);
    text-decoration: none;
  }
  .video-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  @media (max-width: 520px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
