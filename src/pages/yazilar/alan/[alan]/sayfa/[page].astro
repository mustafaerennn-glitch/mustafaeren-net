---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import PressList from '../../../../../components/navigation/PressList.astro';
import PressRow from '../../../../../components/navigation/PressRow.astro';
import Pills from '../../../../../components/navigation/Pills.astro';
import Pagination from '../../../../../components/navigation/Pagination.astro';
import { ALAN_LABELS, ALAN_SLUGS } from '../../../../../lib/taxonomy';
import { type Locale } from '../../../../../i18n/routes';
import LangCountRow from '../../../../../components/metadata/LangCountRow.astro';
import { getContentCountsByLang } from '../../../../../lib/availability';
import { buildYazilarRows, paginateRows, extraPageParams } from '../../../../../lib/pressPagination';

export async function getStaticPaths() {
  const allRows = await buildYazilarRows('tr');
  const paths: { params: { alan: string; page: string } }[] = [];
  for (const alan of ALAN_SLUGS) {
    const areaRows = allRows.filter((row) => row.areas.includes(alan));
    const { totalPages } = paginateRows(areaRows, 1);
    for (const p of extraPageParams(totalPages)) {
      paths.push({ params: { alan, page: p.params.page } });
    }
  }
  return paths;
}

const lang = 'tr';
if (Astro.currentLocale !== lang) {
  throw new Error(`i18n locale eşleşmedi: beklenen "${lang}", Astro.currentLocale="${Astro.currentLocale}"`);
}

const currentAlan = Astro.params.alan as string;
const page = Number(Astro.params.page);
const allRows = await buildYazilarRows(lang);
const areaRows = allRows.filter((row) => row.areas.includes(currentAlan));
const { pageRows: rows, totalPages } = paginateRows(areaRows, page);

const areaCounts: Record<string, number> = {};
for (const row of allRows) {
  for (const a of row.areas) areaCounts[a] = (areaCounts[a] ?? 0) + 1;
}
const pillItems = [
  { label: 'Tümü', count: allRows.length, href: '/yazilar/', active: false },
  ...Object.entries(ALAN_LABELS).map(([slug, label]) => ({
    label,
    count: areaCounts[slug] ?? 0,
    href: `/yazilar/alan/${slug}/`,
    active: slug === currentAlan,
  })),
];

const langCounts = await getContentCountsByLang();
const langItems = (['tr', 'en', 'de', 'fr'] as Locale[]).map((l) => ({
  lang: l,
  href: l === 'tr' ? '/yazilar/' : `/${l}/yazilar/`,
  count: langCounts[l].yazilar,
}));

const alanLabel = ALAN_LABELS[currentAlan];
---

<BaseLayout
  lang={lang}
  title={`Yazılar — ${alanLabel}`}
  description="Hapishane çalışmaları, siyasi tarih, göç ve emek üzerine yazdıklarım."
  canonical={`/yazilar/alan/${currentAlan}/sayfa/${page}/`}
  current="yazilar"
  breadcrumb={[
    { label: 'Ana sayfa', href: '/' },
    { label: 'Yazılar', href: '/yazilar/' },
    { label: alanLabel, href: `/yazilar/alan/${currentAlan}/` },
    { label: `Sayfa ${page}` },
  ]}
>
  <h1>Yazılar</h1>
  <p class="desc">Hapishane çalışmaları, siyasi tarih, göç ve emek üzerine yazdıklarım.</p>

  <LangCountRow currentLang={lang} items={langItems} />

  <Pills items={pillItems} />

  <PressList>
    {rows.map((row) => <PressRow href={row.href} title={row.title} date={row.date} secondary={row.secondary} />)}
  </PressList>

  <Pagination currentPage={page} totalPages={totalPages} basePath={`/yazilar/alan/${currentAlan}/`} />
</BaseLayout>

<style>
  .desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 520px;
    margin: 1rem 0 1.75rem;
  }
</style>
